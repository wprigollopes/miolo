if [ $1 ]; then
    echo "- Creating database 'bis'..."
    su postgres -c "$1/createdb bis"
    
    echo
    echo "- Creating tables and inserting data..."
    su postgres -c "$1/psql -c '\i miolo/modules/common/sql/bis-pgsql.sql' -d bis"
else
    echo "MISSING ARGUMENT 1"
fi
