    <login>
        <module>admin</module>
        <class>mauthDB</class>
        <!--
        <class>mauthLdap</class>
        -->
        <perms>mpermssagu</perms>
        <!--
        <perms>mpermssaguldap</perms>
        <ldap>
            <host>10.0.0.6</host>
            <port>389</port>
