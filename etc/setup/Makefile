####### Build rules

all: Makefile $(TARGET)

$(TARGET):  $(UICDECLS) $(OBJECTS) $(OBJMOC) 
	$(LINK) $(LFLAGS) -o $(TARGET) $(OBJECTS) $(OBJMOC) $(LIBS)

mocables: $(SRCMOC)

$(MOC): 
	( cd $(QTDIR)/src/moc ; $(MAKE) )

Makefile: setup.pro  $(QTDIR)/mkspecs/default/qmake.conf 
	$(QMAKE) -o Makefile setup.pro
qmake: 
	@$(QMAKE) -o Makefile setup.pro

dist: 
	@mkdir -p .tmp/install && $(COPY_FILE) --parents $(SOURCES) $(HEADERS) $(FORMS) $(DIST) .tmp/install/ && ( cd `dirname .tmp/install` && $(TAR) install.tar install && $(GZIP) install.tar ) && $(MOVE) `dirname .tmp/install`/install.tar.gz . && $(DEL_FILE) -r .tmp/install

