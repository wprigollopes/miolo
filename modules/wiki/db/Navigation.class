class BusinessWikiNavigation
{

   function GetDatabase()
   {
      global $MIOLO;
      return $MIOLO->GetDatabase('wiki');
   }
   
   function GetAllProjects(&$range)
   {
      $db = $this->GetDatabase();

      $sql = "select project_id," .
             "       title," .
             "       to_char(creation,'dd/mm/yyyy hh24:mi:ss')," .
             "       to_char(last_update,'dd/mm/yyyy hh24:mi:ss')" .
             " from  projects" .
             " order by last_update";

		$result = $db->QueryRange($sql,$range);
		$db->close();

      return $result;

   }   
}

?>
