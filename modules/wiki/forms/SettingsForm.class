class SettingsForm extends Form
{
    function SettingsForm($data=null)
    {
        global $MIOLO, $module, $login;

        $this->Form(_M("Settings",$module));
        $opts = array ( _M("No",$module), 
                        _M("Yes",$module));

        $fields[] = new Selection(_M('Need login',$module) ,'need_login' ,$data->need_login,$opts,false,_M("Set this to Yes and all the topics would be updated without access check.",$module));
        $fields[] = new Selection(_M('History All',$module),'history_all',$data->history_all,$opts,false,_M("Choose this field to Yes if you want all the topics releases stored.",$module));
        $fields[] = new Selection(_M('Need aproval to comments',$module),'need_comment_aproval',$data->need_comment_aproval,$opts,false,_M("Choose this field to Yes if you want that all the comments sent be checked by the administrator before be showed.",$module));
			
        $this->SetFields($fields);
    }

    function GetData()
    {
        //$required = array('title');

        //if ( $this->Validate($required) )
        {
            $data = $this->CollectInput(new FormData);
        }
        return $data;
    }
}

?>
