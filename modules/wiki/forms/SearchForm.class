class SearchForm extends Form
{
    function SearchForm($data=null)
    {
        global $MIOLO, $module;

        $bus = $MIOLO->GetBusiness($module,'Projects');
        $projects = $bus->GetAllProjects($range); 
        $projects[0] = _M("All",$module);
        $types = array(_M("All",$module),_M("Title",$module),_M("Body",$module), _M("Comments",$module) );
        $this->Form(_M("Searching form",$module));

        $fields[] = new Selection(_M("Project",$module),'project',$data->project,$projects,false);
        $fields[] = new Selection(_M("Search on",$module),'search_on',0,$types);
        $fields[] = new TextField(_M('Text',$module) ,'text',$data->text,30);
			
        $this->SetFields($fields);
    }

    function GetData()
    {
        $required = array('text');

        if ( $this->Validate($required) )
        {
            $data = $this->CollectInput(new FormData);
        }
        return $data;
    }
}

?>
