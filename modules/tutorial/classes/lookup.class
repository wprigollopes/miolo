// Para se usar o lookup deve ser definida uma classe 'lookup'
// no diretio db do mulo (modules/<modulo>/db/lookup.class)
// Este arquivo deve implementar a classe Business<module>Lookup
// que cont駑 as fun鋏es Lookup<item>
// onde o <item> foi definido na cria鈬o do field Lookup

class BusinessTutorialLookup
{

// fun鈬o Lookup<item>: chamada pelo lookup.php para completar/setar os atributos da classe lookup
// com os dados espec凬icos para esta pesquisa

	function LookupFrmAluno_Dados(&$lookup)
    {
        $filterAluno = $lookup->GetFilterValue('filterAluno');
        $filterNome  = $lookup->GetFilterValue('filterNome');
        $filterEmail = $lookup->GetFilterValue('filterEmail');
        $clause      = $lookup->GetFilterValue('clause');

        $lookup->AddFilterField( new TextField('Aluno', 'filterAluno' ,$filterAluno,30));
        $lookup->AddFilterField( new TextField('Nome',  'filterNome', $filterNome,30));
        $lookup->AddFilterField( new TextField('E-Mail','filterEmail',$filterEmail,30));
        $lookup->AddFilterField( new Selection('Compara鈬o','clause',null,
                                               array(' AND ' => '- e -',
                                                     ' OR '  => '- ou -' ) ));
        
        $lookup->SetListingTitle('Alunos encontrados na pesquisa');
        $lookup->SetLabels( array( new ListingColumn(null),
									new ListingColumn('Aluno'),
                                   new ListingColumn('Nome'),
                                   new ListingColumn('Email') ));
        $lookup->SetPageLength(5); // default 20 if not specified
        
        $sql = "select idaluno, idaluno as key, nome, fone, email, datanasc from aluno";
        
        if ( $filterAluno )
        {
            $where .= "$clause ( upper(idaluno) like upper('{$filterAluno}%') )";
        }
        
        if ( $filterNome )
        {
            $where .= "$clause ( upper(nome) like upper('%{$filterNome}%') )";
        }
        
        if ( $filterEmail )
        {
            $where .= "$clause ( upper(email) like upper('{$filterEmail}%') )";
        }
        
        if ( $where )
        {
            $sql .= " where " . substr($where,strlen($clause)+1);
        }
        
        $sql .= " order by nome";

		echo $sql;
        
        $lookup->SetDatabase('tutorial');
        $lookup->SetQuery($sql);
        
    }


}

?>
