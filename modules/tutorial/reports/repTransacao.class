<?
    class repTransacao extends PDFReport
    {
        var $img;
        var $timestamp;

        function __construct()
        {
            global $MIOLO, $module, $page, $context, $self, $action, $perms;

            $ui = $MIOLO->GetUI();
            $this->img = $ui->GetImageSrc('logonet.png');
            $oSistema = $MIOLO->GetBusiness('common', 'sistema');
            $query = $oSistema->ListAll();
            $rsSistema = $query->result;
            $columns = array
                (
                new PDFReportColumn('id', 'Id', 'right', true, 0, false),
                new PDFReportColumn('s.sistema', '<b><i>SISTEMA</i></b>', 'left', true, 35, true, $query->chunkResult(), false, true),
                new PDFReportColumn('t.transacao', '<b><i>TRANSAÇĂO</i></b>', 'left', true, 65, true, null, true)
                );

            $oTransacao = $MIOLO->GetBusiness('common', 'transacao');
            $query = $oTransacao->ListAll();
            $query->SetOrder('sistema,transacao');

            for ($i = 0; $i < 5; $i++)
                foreach ($query->result as $row)
                    $data[] = $row;

            parent::__construct($data, $columns, 25);
            $this->SetColumnAttr('s.sistema', 'index', 2);
            $this->SetColumnAttr('t.transacao', 'index', 1);
            $this->SetIndex(0);
            $this->SetTitle('Relaçăo de Transaçőes');
            $this->SetOption('showTableTitle', 1);
            $this->SetRowMethod('repTransacao', 'MyRowMethod');
            $this->timestamp = date('d/m/Y G:i');
        }

        function MyRowMethod($row, $columns, $slot, $obj)
        {
            if (substr($row[3], 0, 1) == 'S')
            {
                $row[1] .= '*';
            }

            if ($row[2] == $slot['sistema'])
            {
                $row[2] = '';
            }
            else
            {
                $slot['sistema'] = $row[2];
            }
        }

        function GeneratePageHeader()
        {
            $h = $this->pdf->getFontHeight(12);
            //echo $this->img . '<br>';
            $this->pdf->ezImage($this->img, 5, 50, 'none', 'left');
            $this->pdf->addText(90, 800, 12, 'UFJF - Universidade Federal de Juiz de Fora');
            $this->pdf->addText(520, 800, 12, 'Página: ' . $this->pn->pageNumber . '/' . $this->pn->pageCount);
            $this->pdf->addText(90, 800 - $h, 12, 'CGCO - Centro de Gestăo do Conhecimento Organizacional');
            $this->pdf->addText(90, 800 - $h - $h, 12, 'SIGA - Sistema Integrado de Gestăo Acadęmica');
            $this->pdf->ezSetY(800 - $h - $h - $h);
        }

        function GeneratePageFooter()
        {
            $this->pdf->ezText($this->timestamp, 9, array('justification' => 'right'));
        }
    }
?>
