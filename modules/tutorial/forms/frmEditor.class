class frmEditor extends MForm
{
    public function __construct()
    {
        $module = MIOLO::getCurrentModule();
        parent::__construct(_M('Editor', $module));
        $this->eventHandler();
    }

    public function createFields()
    {
        $MIOLO = MIOLO::getInstance();
        $module = MIOLO::getCurrentModule();

        parent::createFields();

        $fields['editor'] = new MEditor('editor');
        $fields['editor']->disableElementsPath();

        $buttons[] = array(MEditor::BUTTON_BOLD, MEditor::BUTTON_SEPARATOR, MEditor::BUTTON_ITALIC);
        // Important: The line separator must be used outside of the sub array
        $buttons[] = MEditor::BUTTON_LINE_SEPARATOR;
        $buttons[] = array(MEditor::BUTTON_ANCHOR, MEditor::BUTTON_FORMAT);

        // Uncomment the next line to change the MEditor default buttons
        //$fields['editor']->setButtons($buttons);

        $this->addFields($fields);

        $valids[] = new MRequiredValidator('editor', 'Editor');
        $this->setValidators($valids);
    }

    public function submit_button_click()
    {
        $data = $this->getData();
        //MIOLO::vd($data->editor);
    }
}
?>
