<?php

class frmToolBar extends MForm
{
    function __construct()
    {
        parent::__construct( _M('ToolBar') );
        $this->eventHandler();
    }

    public function createFields()
    {
        $MIOLO = MIOLO::getInstance();
        $module = MIOLO::getCurrentModule();

        // create a new toolbar
        $fields[] = new MToolBar('toolBar');

        // define fields for the form
        $fields[] = new MTextField('userName', MForm::GetFormValue('userName'), _M('Name') );
        $fields[] = new MTextField('userAddress', MForm::GetFormValue('userAddress'), _M('Address') );
        $fields[] = new MSpacer();

        // set the fields on the form
        $this->setFields($fields);
        // label with
        $this->setLabelWidth('10');
        // set the action of the form's close button
        $this->setClose( $MIOLO->getActionURL($module, 'main:controls') );

        // we don't wanto to show the form's default post button
        $this->setShowPostButton( false );
    }

    public function tbBtnNew_click()
    {
        $this->toolBar->disableButton( MToolBar::BUTTON_NEW );
        $this->toolBar->disableButton( MToolBar::BUTTON_DELETE );
        $this->toolBar->disableButton( MToolBar::BUTTON_SEARCH);

        $text = new MText( 'labelText', _M('New record...') );

        // define the text color
        $sender->color = $text->color = 'blue';

        // add the field to the form
        $this->addField( $text );
    }

    public function tbBtnSave_click()
    {
        $this->toolBar->disableButton( MToolBar::BUTTON_SAVE );

        $text = new MText( 'labelText', _M('Now we should save it... ;-)') );

        // define the text color
        $sender->color = $text->color = 'blue';

        // add the field to the form
        $this->addField( $text );
    }

    public function tbBtnDelete_click()
    {
        $this->toolBar->disableButton( MToolBar::BUTTON_DELETE );
        $this->toolBar->disableButton( MToolBar::BUTTON_SAVE );

        $text = new MText( 'labelText', _M('Deleting your data...') );

        // define the text color
        $sender->color = $text->color = 'blue';

        // add the field to the form
        $this->addField( $text );
    }

    public function tbBtnSearch_click()
    {
        $this->toolBar->disableButton( MToolBar::BUTTON_SEARCH );
        $this->toolBar->disableButton( MToolBar::BUTTON_SAVE );
        $this->toolBar->disableButton( MToolBar::BUTTON_DELETE );

        $text = new MText( 'labelText', _M('Searching, please wait...') );

        // define the text color
        $sender->color = $text->color = 'blue';

        // add the field to the form
        $this->addField( $text );
    }

    public function tbBtnPrint_click()
    {
        $this->toolBar->disableButton( MToolBar::BUTTON_PRINT );
        $this->toolBar->disableButton( MToolBar::BUTTON_SAVE );
        $this->toolBar->disableButton( MToolBar::BUTTON_DELETE );

        $text = new MText( 'labelText', _M('Prepare the printer...') );

        // define the text color
        $sender->color = $text->color = 'blue';

        // add the field to the form
        $this->addField( $text );
    }

    public function tbBtnExit_click()
    {
        $text = new MText( 'labelText', _M('Bye bye, folk...') );

        // define the text color
        $sender->color = $text->color = 'blue';

        // add the field to the form
        $this->addField( $text );
    }

}

?>
