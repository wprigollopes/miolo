<?
$MIOLO->import('modules::tutorial::controls::viewsource');

class frmSession extends Form
{

    function frmSession() 
    {   
        $this->Form('Exemplo do uso de sess„o');
    }
    
    function CreateFields()
    {   
        global $MIOLO, $counter;

        $session = $MIOLO->session;

// se j· estiver na sess„o, pega o valor, sen„o inicializa
        $counter = $session->IsRegistered("counter") ? $session->GetValue("counter") : 0;
// atribuir ao campo
        $this->AddField(new TextLabel('cnt', $counter,'Global'));
// incrementa para o prÛximo round-trip
        $counter++;
// vari·veis globais tem seu valor automaticamente atribuido a $_SESSION
        $session->register("counter");

        $char = (string)$session->IsRegistered("sessionchar") ? $session->GetValue("sessionchar") : 'A';
        $this->AddField(new TextLabel('ch', $char,'Local'));
        $char .= 'A';
// vari·veis locais tem seu valor setado atravÈs de SetValue
        $session->SetValue('sessionchar',$char);

        $this->AddField(new ViewSource(__FILE__));

    }
}
?>