<?xml version="1.0" encoding="ISO-8859-1" standalone="yes"?> 
<form>
   <class>form</class>
   <name>frmXForm</name>
   <painter>form</painter>
   <title>Exemplo de XForm</title>
   <width>95%</width>
   <defaultButton>true</defaultButton>
   <fields>
      <class>associative</class>
      <cmtComment>
         <class>pagecomment</class>
         <name>cmtComment</name>
         <value>Text de comentário</value>
      </cmtComment>
      <sepSeparator>
         <class>separator</class>
	     <name></name>
	     <value>Texto do separador</value>
      </sepSeparator>
     <chkgrpField>
         <class>checkboxgroup</class>
         <name>chkgrpField</name>
         <label>CheckBoxGroup</label>
         <controls>
	         <class>array</class>
	            <item>
                   <class>checkbox</class>
                   <name>chkField1</name>
                   <value></value>
                   <label>CheckBox1</label>
                   <checked>true</checked>
                   <text>Texto1</text> 
                </item>
	            <item>
                   <class>checkbox</class>
                   <name>chkField2</name>
                   <value></value>
                   <label>CheckBox2</label>
                   <checked></checked>
                   <text>Texto2</text> 
                </item>
	            <item>
                   <class>checkbox</class>
                   <name>chkField3</name>
                   <value></value>
                   <label>CheckBox3</label>
                   <checked>true</checked>
                   <text>Texto3</text> 
                </item>
	     </controls>
     </chkgrpField>
     <rbtgrpField>
         <class>radiobuttongroup</class>
         <name>rbtgrpField</name>
         <label>RadioButtonGroup</label>
         <controls>
	         <class>array</class>
	         <item>
                <class>radiobutton</class>
                <name>rbtField</name>
                <value></value>
                <label>RadioButton1</label>
                <checked>true</checked>
	            <text>Texto1</text> 
             </item>
	         <item>
                <class>radiobutton</class>
                <name>rbtField</name>
                <value></value>
                <label>RadioButton2</label>
                <checked></checked>
	            <text>Texto2</text> 
             </item>
	         <item>
                <class>radiobutton</class>
                <name>rbtField</name>
                <value></value>
                <label>RadioButton3</label>
                <checked></checked>
	            <text>Texto3</text> 
             </item>
         </controls>
	     <layout>vertical></layout>
     </rbtgrpField>
     <selMulti>
        <class>multiselection</class>
        <name>selMulti</name>
        <label>MultiSelection</label>
        <value>
	       <class>array</class>
		   <item>0</item>
		</value>
        <options>
	       <class>associative</class>
	          <zero>-zero-</zero>
	          <um>-um-</um>
	          <dois>-dois-</dois>
	          <tres>-tres-</tres>
	          <quatro>-quatro-</quatro>
	          <cinco>-cinco-</cinco>
	          <seis>-seis-</seis>
	    </options>
	    <showValues>0</showValues>
     </selMulti>
  </fields>
  <buttons>
     <class>associative</class>
     <btnPost>
        <class>formbutton</class>
        <name>btnPost</name>
        <label>Enviar</label>
        <action>submit</action>
     </btnPost>
     <btnCancel>
        <class>formbutton</class>
        <name>btnCancel</name>
        <label>Cancelar</label>
        <action>reset</action>
     </btnCancel>
  </buttons>
</form>