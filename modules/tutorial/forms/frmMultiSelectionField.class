<?
class FrmMultiSelectionField extends Form
{

    function FrmMultiSelectionField()
    {   
		global $page;

		$this->Form('Exemplo MultiSelectionField');
        $options_arr1 = Array('op1'=>'OpÁ„o1','op2'=>'OpÁ„o2','op3'=>'OpÁ„o3','op4'=>'OpÁ„o4','op5'=>'OpÁ„o5');
        $options_arr2 = Array(1=>'op1','op2','op3','op4','op5');
        $sel1 = new Selection('sel1','','Selection 1',$options_arr1);
        $sel2 = new Selection('sel2','','Selection 2',$options_arr2);
        $f = array($sel1, $sel2);
        $fields = array(
             new MultiSelectionField('msf',null,'MultiSelectionField',$f,200,true,'Info'),
			 new Text('text'),
		);
		$this->SetFields($fields);
        $this->SetFieldAttr('text','color','blue');
        $buttons = Array(
           new FormButton('btnPost', 'Enviar'),
        );
	    $this->SetButtons($buttons);
        if ( $page->IsPostBack() )
		{
           $this->EventHandler();
		}
	}

    function btnPost_click()
    {
       $value = $this->msf->GetCodeValue();
       $this->AddField(new TableRaw('Campo msf',$value));
    }
}

?>
