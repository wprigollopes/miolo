<?php

class frmTableRaw extends MForm
{
    public function __construct()
    {
        parent::__construct('TableRaw');
    }

    public function createFields()
    {
        $array = array(
            array( 'PHP', 'Tobias Gerken', '2002' ),
            array( 'PHP/XML', 'Juliano Nier', '2001' ),
            array( 'XML', 'Otavio Decio', '2001' ),
            array( 'Flash - The Bible', 'Robert Reinhardt', '2002' ),
            array( 'Javascript', 'Damiani', '2002' )
        );
        $colTitle = array( 'TĒtulo', 'Autor', 'Ano PublicańŃo' );
        $tblZebra = new MTableRaw('', $array);
        $tblZebra->setAlternate(true);
        $fields = array(
            new MSeparator('Com tĒtulos para a tabela e para as colunas'),
            new MTableRaw('RelańŃo de TĒtulos Publicados', $array, $colTitle),
            new MSeparator('Sem tĒtulos para a tabela e para as colunas'),
            new MTableRaw('', $array),
            new MSeparator('Alternate true'),
            $tblZebra
        );
        $this->setFields($fields);
        $this->defaultButton = false;
    }
}
?>
