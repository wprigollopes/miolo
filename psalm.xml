<?xml version="1.0"?>
<psalm
    errorLevel="7"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    findUnusedBaselineEntry="true"
    findUnusedCode="true"
>
    <projectFiles>
        <directory name="html" />
        <directory name="classes" />
        <directory name="modules" />
        <directory name="bin" />
        <ignoreFiles>
            <directory name="vendor" />
            <!-- Third-party libraries -->
            <directory name="html/scripts" />
            <directory name="classes/ezpdf" />
            <directory name="classes/extensions" />
            <directory name="classes/pslib" />
            <directory name="modules/generator/classes/wizindent" />
            <!-- Code generator templates (not real PHP) -->
            <directory name="bin/templates" />
        </ignoreFiles>
    </projectFiles>
</psalm>
