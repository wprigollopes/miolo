    class DevelopmentTime
    {
        
        function DefineRights($module, $login, $access)
        {
            global $MIOLO;
            
            $MIOLO->SetDatabase('bis');
                     
            $db  = $MIOLO->GetDatabase();
            
            $sql = "DELETE FROM cmn_access " .
                   " WHERE module='$module' AND login='$login'";
                   
            $db->Execute($sql);
            
            unset($sql);
            
            foreach($access as $action=>$value)
            {
                $state = $value ? 'true' : 'false';
                
                $sql[] = "INSERT INTO cmn_access(module, login, action, fl_access) " .
                         "VALUES ('$module', '$login', '$action', $state)";
            }
            
            $err = $db->GetErrors();
            
            $db->Execute($sql);
        }
        
    }

?>
