#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# MIOLO Main Class
#---------------------------------------------------------------------
class MIOLO
{    
    // remote tracing log message support
    var $trace_socket;
    
    // Standard settings
    var $html_home;
    var $logs_home;
    var $miolo_home;
    var $module_home;

    // Browser side
    var $url_base;
    var $dispatch;
    
    // Options
    var $debug;
    var $dump;
    
    // BD descriptor members
    var $db;
    var $user;
    var $pass;
    var $sqllog;
    var $errlog;
    
    // Other members
    var $theme;
    var $painter;
    var $profile;
    var $uses;
    var $trace;
    var $error;
    var $login;
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Class Constructor
    #---------------------------------------------------------------------
    function MIOLO($home=null,$logname='miolo')
    {   global $MIOLOCONF;
        
        $this->Trace("Constructing main class",__FILE__,__LINE__);
        
        // must be a reference to session login
        $this->login       =& $_SESSION['login'];
        
        $this->html_home   = $MIOLOCONF['home']['html'];
        $this->logs_home   = $MIOLOCONF['home']['logs'];
        $this->miolo_home  = $MIOLOCONF['home']['miolo'];
        $this->module_home = $MIOLOCONF['home']['modules'];
        $this->url_base    = $MIOLOCONF['home']['url'];
        $this->dispatch    = $MIOLOCONF['home']['url'] . '/' . $MIOLOCONF['options']['dispatch'];
        
        // wether to show debug info or not 
        $this->debug       = $MIOLOCONF['options']['debug'];
        
        // wether to dump internal information or not
        $this->dump        = $MIOLOCONF['options']['dump'];
        
        if ( $home )
        {
            $this->home = $home;
        }
        
        $this->SetLog($logname);
           
        $this->Uses('login.class');
        $this->Uses('context.class');
        $this->Uses('types.class');
        $this->Uses('error.class');
        $this->Uses('success.class');
        $this->Uses('ui/themetoolkit.class');
        $this->Uses('ui/theme.class');
        $this->Uses('ui/statusbar.class');
        $this->Uses('status.class');
        $this->Uses('../modules/modules.inc');

        $this->Uses('development_time.class');
        
        $this->theme = new Theme();
        $this->theme->AddScript('common.js');
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Sets the root request dispatcher (e.g. the url that will be used in
    # action URLs).
    #---------------------------------------------------------------------
    function SetDispatcher($url)
    {
        $this->dispatch = $url;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Sets the path for the log file
    #---------------------------------------------------------------------
    function SetLog($logname)
    {   global $MIOLOCONF;
        
        $this->Assert($logname, 'MIOLO::SetLog:' . _M('Empty database configuration name!'));
        
        $this->errlog  = $this->logs_home . "/$logname-error.log";
        $this->sqllog  = $this->logs_home . "/$logname-sql.log";
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Handler for assertions. If the condition <code>$cond</code> of an
    # assertion fails (evaluates to false), an error message is shown and
    # the script execution is halted.
    #---------------------------------------------------------------------
    function Assert($cond,$msg='',$goto='')
    {
        if ( $cond == false )
        {
            $this->LogMessage('[ERROR]'.$msg);
            
            $this->Error($msg,$goto,_M('Fatal Error'));
        }
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Obtains the theme painter. Which object will be returned depends on
    # the configuration of the current theme.
    # <br><br>
    # Usually this function will be called from the GenerateTheme() method.
    #---------------------------------------------------------------------
    function & GetThemePainter()
    {   global $MIOLOCONF;
        
        if ( ! $this->painter )
        {
            $this->Uses('ui/themepainter.class');
            
            $theme_file = $MIOLOCONF['home']['themes'] . '/' . $MIOLOCONF['theme']['main'] . '/theme.class';
            //$this->Uses( $theme_file, 'html');
            //$this->Uses( $theme_file, 'html');
            $this->Uses( '/themes/'. $MIOLOCONF['theme']['main'] . '/theme.class', 'html_home');
            
            //$this->Dump($theme_file);
            // return a reference to the theme painter
            $this->painter = new MyThemePainter();
        }
        
        return $this->painter;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Obtains a reference to the current theme object. The theme is a 
    # logical container for our pages.
    #---------------------------------------------------------------------
    function & GetTheme()
    {
        return $this->theme;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Sets the current theme object
    #---------------------------------------------------------------------
    function SetTheme(&$theme)
    {
        $this->theme =& $theme;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Generates the content of the current theme object
    #---------------------------------------------------------------------
    function GenerateTheme()
    {
        $this->Trace('GenerateTheme');
        $painter =& $this->GetThemePainter();
        $this->ProfileEnter("ThemePainter::Generate");
        $painter->GenerateTheme($this->theme);
        $this->ProfileExit("ThemePainter::Generate");
        $this->ProfileDump();
        exit;  // shall we exit, when the theme has been generated???
    }
     
     
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # TODO: TRANSLATION
    # Este metodo compoe um link para uma URL no sistema.
    # <br>
    # @example
    # ...
    # $module = 'reports';
    # $main   = 'main:list_person';
    #
    # $handler = $MIOLO->GetActionURL($module, $main);
    # ...
    # O exemplo acima retorna um link para o handler list_person.inc, no
    # modulo reports: http://nome_site/handler.php?module=reports&action=main:list_person
    #
    # @param $module (string) Nome do modulo que sera acessado
    # @param $action (string) Nome do handler (<code>.inc</code>) a ser acessado
    # @param $item   (string) Parametro adicional que pode ser utilizado
    #                         para passar dados para a nova pagina.
    # @param $args (string/array) Esse argumento pode ser utilizado para criar
    #        outras variaveis, alem das tres anteriores (que sao padrao do MIOLO).
    #        Quando for informado um array, o <code>key</code> sera o nome da variavel atraves
    #        do qual o conteudo podera ser acessado.
    # @param $dispatch (string) Indica qual arquivo devera ser utilizado
    #        ao inves daquele configurado no miolo.conf: 
    #        <code>$MIOLOCONF['options']['dispatch']</code>
    #
    # @returns (string) o link para uma URL
    #---------------------------------------------------------------------
    function GetActionURL($module='', $action='NONE', $item='', $args=null , $dispatch=null)
    {   global $MIOLOCONF;
    
        if ( ! $dispatch )
        {
            $dispatch = $this->dispatch;
        }
        
        //$url = "$dispatch?module=$module&action=$action";
        $url = "module=$module&action=$action";
        
        if ( $item )
        {
            $url .= "&item=$item";
        }
        
        if ( is_array($args) )
        {
            foreach( $args as $key=>$value)
            {
                $url .= "&$key=$value";
            }
        }
        
        if ( $MIOLOCONF['options']['scramble'] )
        {   
            $url = "MIOLO_URI=" . $this->Scramble($url);
        }
        
        $url = "$dispatch?".$url;
        
        return $url;
    }
    
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # TODO: TRANSLATION
    # Este metodo eh utilizado para criptografar uma string. Eh utilizado 
    # principalmente pelo metodo GetActionURL
