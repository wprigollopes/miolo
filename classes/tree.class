    /**
     * It is assumed, that 'parent' node already exists
     */
    function AddItem($id,$parent,$data)
    {
        if ( ! $parent )
          $parent = & $this->root;
          
        $node = FindNode($this->root,$parent);
        
        
    }
    
    /**
     * Retrieves the 
     */
    function & FindNode(&$parent,$id)
    {
        if ( ! $parent )
          return null;
          
        foreach ( $parent as $key => $data )
        {
            if ( $key == $id )
              return $data;
            
            $node = & $this->FindNode(& $data);
            
            if ( $node )
              return $node;
        }
        
        return null;
    }
    
