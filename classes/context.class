/**
 *
 */
class Context
{
    var $module;
    var $action;
    var $item;
    var $actionTokens;
    var $currentToken;
    
    function Context()
    {   global $MIOLOCONF;
    
        if ( ( $MIOLOCONF['options']['scramble'] ) &&
            ( $_REQUEST['MIOLO_URI'] )
            )
        {
            $url = MIOLO::UnScramble( $_REQUEST['MIOLO_URI'] );
            $url = explode('&', $url);

            foreach ( $url as $u )
            {
                $u = '$'.$u."';";
                $u = ereg_replace('=',"='", $u);

                eval("$u");
            }
        }
        else
        {
            $module = $_REQUEST['module'];
            $action = $_REQUEST['action'];
            $item   = $_REQUEST['item'];
        }
        
        $this->Create($module,
                      $action,
                      $item
                      );
    }
    
    function Create($module,$action,$item)
    {   global $MIOLO;
        
        $MIOLO->Trace("Context::Create(module=$module,action=$action,item=$item)");
        
        $this->module = $module;
        $this->action = $action;
        $this->item   = $item;
        
        $this->actionTokens = explode(':',$this->action);
        $this->currentToken = 0;
    }
    
    function GetAction($index=0)
    {
        $action = $index>=0 && $index<count($this->actionTokens) ? 
                  $this->actionTokens[$index] : null;
        
        return $action;                      
    }
    
    function ShiftAction()
    {   global $MIOLO;
        
        $action = $this->currentToken < count($this->actionTokens) ? 
        $this->actionTokens[$this->currentToken++] : null;
        
        $MIOLO->Trace("Context::ShiftAction() => $action");
        
        return $action;
    }
    
    function PushAction($a)
    {
        if ( $this->action )
        {
            $this->action .= ':';
        }
        
        $this->action .= $a;
        
        $this->actionTokens = explode(':',$this->action);
        $this->currentToken = 0;
    }
    
    function DEPRECATED_ComposeURL()
    {    
        return "?module=$this->module" .
               "&action=$this->action" .
               "&item=$this->item";
    }
}

?>
