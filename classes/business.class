class Business
{
    var $errors;
    
    function CheckError($db)
    {
        $err = $db->GetError();
        
        if ( $err )
        {   
            $this->errors[] = $err;
        }
        
        return count($this->errors)>0;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Obtains the last DB errors
    #---------------------------------------------------------------------
    function GetErrors()
    {
        return $this->errors;
    }
}

?>
