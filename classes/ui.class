class UI
{
    function UI()
    { global $MIOLO;
        
        $MIOLO->Uses('ui/form.class');
        $MIOLO->Uses('ui/listing.class');
        $MIOLO->Uses('ui/statusbar.class');
        $MIOLO->Uses('ui/pagenavigator.class');
        $MIOLO->Uses('ui/tabbedform.class');
        $MIOLO->Uses('ui/tabbedform2.class');
        $MIOLO->Uses('ui/indexedform.class');
        $MIOLO->Uses('ui/inputgrid.class');
    }
    
    function Alert($msg,$info,$href='')
    { global $MIOLO;
        
        $MIOLO->Error($msg,$info,$href);
    }
    
    function CreateForm($title='')
    {
        return new Form($title);
    }
    
    function GetForm($module,$name,$data=null)
    { global $MIOLO;
        
        $MIOLO->Uses( 'types.class', $module);
        
        $file = "forms/$name.class";
        
        $MIOLO->Assert(file_exists($MIOLO->GetModulePath($module,$file)),
                       'UI::GetForm() ' . _M('Error: @1 - file not found.','miolo',$file) );
        
        $MIOLO->Uses( $file, $module);
        
        // Workaround: adds module's prefix to class name
        $class = strtoupper(substr($module,0,1)) . substr($module,1) . $name;

        if ( ! class_exists($class) )
        {
            $MIOLO->Deprecate("You should name your form class '$class' instead of '$name'!");
            
            $class = $name;
        }
        
        if ( $data )
        {
          eval("\$form = new $class(\$data);");
        }
        else
        {
          eval("\$form = new $class();");
        }
        
        return $form;
    }
    
    function GetMenu($module='main',$name='UIMainMenu')
    { global $MIOLO;
        
        $MIOLO->Uses("menus/$name.class",$module);
        
        eval("\$menu = new $name();");
        
        return $menu;
    }
    
    function GetImage($module,$nome)
    {
        if ( $module )
        $img = $MIOLO->GetAbsoluteURL('/modules/' . $module . '/images/' . $nome);
        
        else
        $img = $MIOLO->GetAbsoluteURL('/images/' . $nome);
        
        return $img;
    }
}

?>
