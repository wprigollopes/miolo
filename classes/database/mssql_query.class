/**
 *
 */
class MssqlQuery
{
    var $conf;     // name of database configuration
    var $conn;     // the connection id
    var $sql;      // the SQL command string
    var $result;   // the SQL command result set
    var $row;      // the current row index
    var $error;    // the query's error message from the query execution

    function MssqlQuery($conf)
    {
        $this->conf = $conf;
    }

    function GetError()
    {
		return $this->error;
    }

    function Open()
    {   global $MIOLO;

        $MIOLO->LogSQL($this->sql,false,$this->conf);

        ob_start();
        $this->result = mssql_query($this->sql,$this->conn->id);
        $this->row    = -1;

        if (!$this->result) {
            $sql_error=$this->conn->treat_mssql_error(ob_get_contents()); 
            $this->error = $sql_error;
            ob_end_clean(); 
        }
        ob_end_clean(); 

        return $this->result != null;
    }

    function Close()
    {
        if ( $this->result != null )
        {
            mssql_free_result($this->result);

            $this->result = null;
        }
    }

    function MovePrev()
    {
        if ( $this->row >= 0 )
        {
            $this->row--;

            return true;
        }

        return false;
    }

    function MoveNext()
    {
        if ( $this->row + 1 < $this->GetRowCount() )
        {
            $this->row++;

            return true;
        }

        return false;
    }

    function GetRowCount()
    {
        if ($this->result != 0) {
		  return mssql_num_rows($this->result);
		}
    }

    function GetColumnCount()
    {
        return mssql_num_fields($this->result);
    }

    function GetColumnName($col)
    {
        return mssql_field_name($this->result,$col-1);
    }

    function GetValue($col)
    {
        return mssql_result($this->result,$this->row,$col-1);
    }

    function GetRowValues()
    {
        return mssql_fetch_row($this->result);
    }

    function SetConnection($c)
    {
        $this->conn = $c;
    }

    function SetSQL($sql)
    {
        $this->sql  = $sql;
    }
}

?>
