/**
*
*/
class MysqlQuery
{
    var $conf;     // name of database configuration
    var $conn;     // the connection id
    var $sql;      // the SQL command string
    var $result;   // the SQL command result set
    var $row;      // the current row index
    var $error;    // the error message from the query execution
    
    function GetError()
    {
    return $this->error;
    }

    function MysqlQuery($conf)
    {
        $this->conf = $conf;
    }
    
    function Open()
    { global $MIOLO;
        
        $MIOLO->LogSQL($this->sql,false,$this->conf);
        
        $this->result = mysql_query($this->sql,$this->conn->id); 
        $this->row    = -1;
        
        $this->error = mysql_error();
        
        return $this->result != null;
    }
    
    function Close()
    {
        if ( $this->result != null )
        {
            @mysql_free_result($this->result);
            
            $this->result = null;
        }
    }
    
    function MovePrev()
    {
        if ( $this->row >= 0 )
        {
            $this->row--;
            
            return true;
        }
        
        return false;
    }
    
    function MoveNext()
    {
        if ( $this->row + 1 < $this->GetRowCount() )
        {
            $this->row++;
            
            return true;
        }
        
        return false;
    }
    
    function GetRowCount()
    {
        return @mysql_numrows($this->result);
    }
    
    function GetColumnCount()
    {
        return mysql_numfields($this->result);
    }
    
    function GetColumnName($col)
    {
        return mysql_field_name($this->result,$col-1);
    }
    
    function GetValue($col)
    {
        return mysql_result($this->result,$this->row,$col-1);
    }
    
    function GetRowValues()
    {
        $rc = mysql_data_seek($this->result,$this->row);
    
        return mysql_fetch_row($this->result);
    }
    
    function SetConnection($c)
    {
        $this->conn = $c;
    }
    
    function SetSQL($sql)
    {
        $this->sql  = $sql;
    }
};

?>
