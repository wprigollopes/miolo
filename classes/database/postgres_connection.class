/**
 *
 */
class PostgresConnection
{
    var $conf;       // name of database configuration
    var $id;         // the connection identifier
    var $traceback;  // a list of transaction errors
    var $level;      // a counter for the transaction level
    
    function PostgresConnection($conf)
    {   global $MIOLO;

        $this->conf = $conf;
        
        $MIOLO->Uses('database/postgres_query.class');
    }

    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Opens a connection to the specified data source
    #---------------------------------------------------------------------
    function Open($dbhost,$LoginDB,$LoginUID,$LoginPWD,$persistent=true)
    {   global $MIOLO, $php_errormsg;
        
        if ( $this->id )
        {
            Close();
        }
        
        $this->traceback = null;
        $this->level = 0;

        $arg = "host=$dbhost " .
               "dbname=$LoginDB " .
               "port=5432 " .
               "user=$LoginUID " .
               "password=$LoginPWD";

        // $MIOLO->Dump($arg,__FILE__,__LINE__);

        if ( false && $persistent )
        {
            $this->id = pg_pConnect($arg);
        }
        else
        {
            $this->id = pg_Connect($arg);
        }

        if ( ! $this->id )
        {
            $this->traceback[] = "Unable to estabilish DataBase Conection to host: $dbhost, DB: $LoginDB";
        }
        
        return $this->id;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # closes a previously opened connection
    #---------------------------------------------------------------------
    function Close()
    {
        if ( $this->id )
        {   global $MIOLO;
            
            $MIOLO->Assert($this->level==0,"Transactions not finished!");
            
            pg_close($this->id);
            
            $this->id = 0;
        }
    }
    
    
    function Begin()
    {
        $this->Execute("begin transaction");
        
        $this->level++;
    }
    
    
    function Finish()
    {   global $MIOLO;
        
        $MIOLO->Assert($this->level>0,"Transaction level underrun!");
        
        $success = $this->GetErrorCount() == 0;
        
        if ( $success )
        {
            $this->Execute("commit");
        }
        else
        {
            $this->Execute("rollback");
        }
        
        $this->level--;
        
        return $success;
    }
    
    
    function GetError()
    {
        
        if ( ! $this->id )
        {
            $err = "No valid Database connection estabilished.";
           
            if ( $this->traceback )
            {
                $err .= "<br>" . implode("<br>", $this->traceback);
            }
            
        }
        else
        {
            $err = pg_errormessage($this->id);
        }
        
        return $err;
    }
    
    
    function GetErrors()
    {
        return $this->traceback;
    }
    
    function GetErrorCount()
    {
        return empty($this->traceback) ? 0 : count($this->traceback);
    }
    
    
    function CheckError()
    {   global $MIOLO;
        
        if ( empty($this->traceback) )
        {
            return;
        }
        
        $n = count($this->traceback);
        
        if ( $n > 0 )
        {
            $msg = "";
            
            for ( $i=0; $i<$n; $i++ )
            {
                $msg .= $this->traceback[$i] . "<br>";
            }
            
            $MIOLO->Assert(false ,"Transaction Error",$msg);
        }
    }
  
    
    function Execute($sql)
    {   global $MIOLO;
        
        $MIOLO->LogSQL($sql, false, $this->conf);
        
        if ( $this->level == 0 )
        {
            $this->traceback = null;
        }
        
        $rs = pg_exec($this->id,$sql);
        
        if ( $rs )
        {
            // Permite utilizar "RETURNING" na query
            if (pg_result_status($rs) == PGSQL_TUPLES_OK)
            {
                $return = pg_fetch_all($rs);
            }
            else
            {
                $return = true;
            }
            
            pg_freeresult($rs);
            
            return $return;
        }
        else
        {
            $this->traceback[] = $this->GetError();
        }
        
        return false;
    }
    
    
    function ExecuteAffect($sql)
    {
        global $MIOLO;
    
        $MIOLO->LogSQL($sql,false,$this->conf);
    
        if ( $this->level == 0 )
        {
            $this->traceback = null;
        }
    
        if ( is_array($sql) )
        {
            foreach ( $sql as $row )
            {
                $rs = pg_query($this->id,$row);
                $rs = pg_affected_rows($rs);
                $this->traceback[] = $this->GetError();
            }
        }
        else
        {
            $rs = pg_query($this->id,$sql);
            $rs = pg_affected_rows($rs);
            $this->traceback[] = $this->GetError();
        }
    
        return $rs;
    }    
    

    function CreateQuery($sql="")
    {   global $MIOLO;
        
        $MIOLO->Assert($this->id, $this->GetErrors());
        
        $q = new PostgresQuery($this->conf);
        
        $q->conn   = $this;
        $q->sql    = $sql;
        $q->result = 0;
        $q->row    = -1;
        
        if ( $sql != "" )
        {
            $q->Open();
        }
        
        return $q;
    }

};

?>
