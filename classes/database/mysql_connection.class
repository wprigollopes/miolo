/**
 *
 */
class MysqlConnection
{
    var $conf;       // name of database configuration
    var $id;         // the connection identifier
    var $traceback;  // a list of transaction errors
    var $level;      // a counter for the transaction level
    
    function MysqlConnection($conf)
    {   global $MIOLO;

        $this->conf = $conf;

        $MIOLO->Uses('database/mysql_query.class');
    }

    // opens a connection to the specified data source
    function Open($dbhost,$dbname,$dbuser,$dbpass,$persistent=true)
    {   global $MIOLO;

        if ( $this->id )
        {
          Close();
        }

        $arg = $dbhost . ':' . ( $mysql_sock ? $mysql_sock : '/tmp/mysql.sock' );

        $this->id = mysql_pconnect($arg,$dbuser,$dbpass);
        $this->traceback = null;
        $this->level = 0;

        // $MIOLO->Dump($arg,__FILE__,__LINE__);

        $rc = mysql_select_db($dbname,$this->id);
            
        return $this->id;
    }
    
    // closes a previously opened connection
    function Close()
    {
        if ( $this->id )
        {   global $MIOLO;
            
            $MIOLO->Assert($this->level==0,"Transactions not finished!");
            
            mysql_close($this->id);

            $this->id = 0;
        }
    }
    
    function Begin()
    {
        $this->Execute("begin transaction");
        
        $this->level++;
    }
    
    function Finish()
    {   global $MIOLO;
        
        $MIOLO->Assert($this->level>0,"Transaction level underrun!");
        
        $success = $this->GetErrorCount() == 0;
        
        if ( $success )
        {
            $this->Execute("commit");
        }
        else
        {
            $this->Execute("rollback");
        }
        
        $this->level--;
        
        return $success;
    }
    
    function GetError()
    {
        return mysql_error();
    }
    
    function GetErrors()
    {
        return $this->traceback;
    }
    
    function GetErrorCount()
    {
        return empty($this->traceback) ? 0 : count($this->traceback);
    }
    
    function CheckError()
    { global $MIOLO;
        if ( empty($this->traceback) )
        return;
        
        $n = count($this->traceback);
        
        if ( $n > 0 )
        {
            $msg = "";
            
            for ( $i=0; $i<$n; $i++ )
            {
                $msg .= $this->traceback[$i] . "<br>";
            }
            
            $MIOLO->Assert(false ,"Transaction Error",$msg);
        }
    }
    
    function Execute($sql)
    { global $MIOLO;
        
        $MIOLO->LogSQL($sql,false,$this->conf);
        
        $this->traceback = null;
        
        $rs = mysql_query($sql,$this->id);
        
        $success = false;
        
        if ( $rs )
        {
            $success = true;
            
            @mysql_free_result($rs);
        }
        
        else
        {
            $this->traceback[] = $this->GetError();
        }
        
        return $success;
    }
    
    function CreateQuery($sql="")
    { global $MIOLO;
        
        $MIOLO->Assert($this->id,"MysqlConnection: CreateQuery: Connection ID");
        
        $q = new MysqlQuery($this->conf);
        
        $q->conn   = $this;
        $q->sql    = $sql;
        $q->result = 0;
        $q->row    = -1;
        
        if ( $sql != "" )
        {
            $q->Open();
        }
        
        return $q;
    }
}

?>
