// ----------------------------------------------------------------------
//
// ----------------------------------------------------------------------
class TextField extends FormField
{
    var $size;
    var $type;
    var $validator;
    var $autoSubmit;
   
    function TextField($label,$name,$value='',$size=10,$hint='',$validator=null)
    {
        $this->FormField($label,$name,$value,$hint);
        
        $this->size = $size;
        $this->type = $size ? 'text' : 'hidden';
        $this->validator = is_string($validator) ? 
                               Validator::MASKValidator($validator) : $validator;
    }

    
    function SetAutoSubmit($state)
    {
        $this->autoSubmit = $state;
    }
    
    
    function Generate()
    {
      if ( $this->label && $this->type=='hidden' )
      {
          echo $this->value;
      }
      
      echo "<input name=\"$this->name\" type=\"$this->type\" value=\"$this->value\""; 

      if ( $this->type=='text' && $this->size )
      {
          echo " size=\"$this->size\"";
      }
      
      if ( $this->autoSubmit )
      {
          echo " onChange=\"document." . $this->form->GetName() . ".submit();\" ";
      }
      
      if ( $this->validator )
      {
          if ( $this->validator->type == 'readonly' )
          {
              echo " disabled style=\"color:blue;\"";
          }
          else
          {
              $obj = $this->form->AddValidation($this);
              
              if ( $this->validator->mask )
              {
                  echo " onKeyPress=\"return MIOLO_Validate_Mask($obj,event)\"";
                  echo " onFocus=\"MIOLO_Validate_Mask($obj)\"";
              }
          }
      }
      
      echo ">\n";
    }
}

class Validator
{
    var $name;
    var $form;
    var $field;
    var $label;
    var $min;
    var $max;
    var $type = 'required';  // ex. required | optional | ignore/ readonly
    var $chars;
    var $mask;
    var $checker;
    
    function Validator()
    {
    }
    
    
    function MASKValidator($mask,$type = 'ignore')
    {
        $validator = new Validator();
        $validator->mask  = $mask;
        $validator->type  = $type;
        $validator->min   = 0;
        $validator->max   = strlen($mask);
        $validator->chars = null;
        
        return $validator;
    }
    
    
    function EMAILValidator($type = 'optional')
    {
        $validator = new Validator();
        $validator->type  = $type;
        $validator->min   = 0;
        $validator->max   = 99;
        $validator->chars = 'ALL';
        $validator->mask  = '';
        $validator->checker = 'EMAIL';
        
        return $validator;
    }
    
    
    function CEPValidator($type = 'optional')
    {
        $validator = new Validator();
        $validator->type  = $type;
        $validator->min   = 9;
        $validator->max   = 9;
        $validator->chars = '0123456789-';
        $validator->mask  = '99999-999';
        
        return $validator;
    }
    
    
    function PHONEValidator($type = 'optional')
    {
        $validator = new Validator();
        $validator->type  = $type;
        $validator->min   = 13;
        $validator->max   = 13;
        $validator->chars = '() 01234-56789';
        $validator->mask  = '(99)9999-9999';
        
        return $validator;
    }
    
    
    function TIMEValidator($type = 'optional')
    {
        $validator = new Validator();
        $validator->type    = $type;
        $validator->min     = 5;
        $validator->max     = 5;
        $validator->chars   = ':0123456789';
        $validator->mask    = '99:99';
        $validator->checker = 'TIME';
        
        return $validator;
    }
    
    
    function CPFValidator($type = 'optional')
    {
        $validator = new Validator();
        $validator->type    = $type;
        $validator->min     = 14;
        $validator->max     = 14;
        $validator->chars   = '.-0123456789';
        $validator->mask    = '999.999.999-99';
        $validator->checker = 'CPF';
        
        return $validator;
    }
    
    function CNPJValidator($type = 'optional')
    {
        $validator = new Validator();
        $validator->type    = $type;
        $validator->min     = 18;
        $validator->max     = 18;
        $validator->chars   = '/.-0123456789';
        $validator->mask    = '99.999.999/9999-99';
        $validator->checker = 'CNPJ';
        
        return $validator;
    }
    
    function DATEDMYValidator($type = 'optional',$sep='/')
    {
        $validator = new Validator();
        $validator->type  = $type;
        $validator->min   = 10;
        $validator->max   = 10;
        $validator->chars = $sep.'0123456789'; // The first list item is the date separator
        $validator->mask  = '99'.$sep.'99'.$sep.'9999';
        $validator->checker = 'DATEDMY';
        
        return $validator;
    }
    
    
    function DATEYMDValidator($type = 'optional')
    {
        $validator = new Validator();
        $validator->type  = $type;
        $validator->min   = 10;
        $validator->max   = 10;
        $validator->chars = '/0123456789';
        $validator->mask  = '99/99/9999';
        $validator->checker = 'DATEYMD';
        
        return $validator;
    }
    
    
    function Generate()
    {
        $name = $this->name;

        echo "var $name = new MIOLO_Validator();\n";
        echo "$name.form = '{$this->form}';\n";
        echo "$name.field = '{$this->field}';\n";
        echo "$name.label = '{$this->label}';\n";
        echo "$name.min = {$this->min};\n";
        echo "$name.max = {$this->max};\n";
        echo "$name.type = '{$this->type}';\n";
        echo "$name.chars = '{$this->chars}';\n";
        echo "$name.mask = '{$this->mask}';\n";
        
        if ( $this->checker )
        {
            echo "$name.checker = 'MIOLO_Validate_Check_{$this->checker}';\n";
        }
    }    
}


