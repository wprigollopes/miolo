define ('FORM_SUBMIT_BTN_NAME', 'frm_submit_button');

#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# The form class is the base class to construct a HTML form. Along
# with this class, different form object classes are defined, such as
# input fields (TextField), choices (Selection), check and radio
# boxes.
#---------------------------------------------------------------------
class Form
{
    var $title;
    var $name;
    var $action;
    var $method;
    var $buttons;
    var $fields;
    var $return;
    var $reset;
    var $styles;
    var $help;
    var $footer;
    var $width;
    var $onsubmit;
    var $showHints = true;
    var $enctype;
    var $validations;
    var $focus;
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This is the constructor of the Form class. It takes a title and an
    # action url as optional parameters. The action URL is typically 
    # obtained by calling the <code>MIOLO->GetActionURL()</code> method.
    #
    # @param $title  (string) the form's title string
    # @param $action (string) the URL for the forms <code>ACTION</code>
    #                attribute.
    #---------------------------------------------------------------------
    function Form($title='',$action='')
    {
        $this->title  = $title;
        $this->name   = 'frm' . getmypid();
        $this->action = $action;
        $this->method = 'post';
        $this->return = false;
        $this->width  = '100%';
    }
    
    function AddValidation(&$field)
    {
        $name = '_validator_' . $this->name . '_' . $field->name;
        
        $field->validator->name  = $name;
        $field->validator->form  = $this->name;
        $field->validator->field = $field->name;
        $field->validator->label = $field->label;
        
        $this->validations[] = & $field->validator;
        
        // if this was the first validation, add the validation code to the
        // onSubmit handler
        if ( count($this->validations) == 1 )
        {
            $this->OnSubmit("MIOLO_Validate_Input({$this->name}_validations)");
        }
        
        return $name;
    }

    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Obtains the name of this form.
    #
    # @returns (String) the name of the form
    #---------------------------------------------------------------------
    function GetName()
    {
        return $this->name;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Detects if a form has been submitted.
    #
    # @returns (boolean) true if the form has been submitted otherwise 
    #                    false
    #---------------------------------------------------------------------
    function /* static */ IsSubmitted()
    {
        return isset( $_POST[FORM_SUBMIT_BTN_NAME] );
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Obtains the content of this form's title. Observe, that this
    # can be anything other as a simple text string too, such as array of
    # strings and an object implementing the <code>Generate()</code> method.
    #
    # @returns (Mixed &) a reference to the title of the form
    #---------------------------------------------------------------------
    function & GetTitle()
    {
        return $this->title;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Sets the form's title content
    #---------------------------------------------------------------------
    function SetTitle($title)
    {
        $this->title = $title;
    }

    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Obtains the content title of this form's footer. Observe, that this
    # can be anything other as a simple text string too, such as array of
    # strings and an object implementing the <code>Generate()</code> method.
    #
    # @returns (Mixed &) a reference to the footer of the form
    #---------------------------------------------------------------------
    function & GetFooter()
    {
        return $this->footer;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Sets the form's footer content
    #---------------------------------------------------------------------
    function SetFooter($footer)
    {
        $this->footer = $footer;
    }

    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Obtains a submitted form field's value. This is a static function
    # which takes in account that the Form class adds a prefix 'frm_' to
    # all form variables. So when calling this function, the caller has
    # to omit the prefix, using the same name, which was used in the
    # field definition
    #
    # @returns (mixed) value of field contained in <code>$_POST</code>  
    #---------------------------------------------------------------------
    function /* static */ GetFormValue($name,$value=false)
    {
        return isset( $_POST['frm_'.$name] ) ?
                      $_POST['frm_'.$name]   : $value;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Sets the content of a form field to the specified value. The 
    # function does this by setting both, the field's value member and the
    # global <code>$_REQUEST</code> to remain consistency between the values.
    # It is expected, that the caller passes the same name as of the
    # field definition (e.g. w/o 'frm_' prefix).
    #---------------------------------------------------------------------
    function SetFormValue($name,$value)
    {
        $value = Form::EscapeValue($value);
        
        // the name of the global variable referring the field
        $name = 'frm_' . $name;  
        
        $n = count($this->fields);
        
        for ( $i=0; $i<$n; $i++ )
        { 
            if ( $this->fields[$i]->name == $name )
            {
                if ( get_class($this->fields[$i]) == 'checkBox' )
                {
                    $this->fields[$i]->checked = $value;
                }
                else
                {
                    $this->fields[$i]->value = $value;
                }
            }
        }
            
        $_REQUEST[$name] = $value;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Used to escapes special characters contained in a form field's value
    # Currently, only simple and double quote characters are subsituted
    # with their corresponding HTML entities.
    #
    # This function is used internally by some of the form's methods.
    #
    # @returns (string) the translated string
    #---------------------------------------------------------------------
    function /* PRIVATE */ EscapeValue($value)
    {
        $value = str_replace('\"','&quot;',$value);
        $value = str_replace('"','&quot;',$value);
        
        return $value;
    }

    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Adds JavaScript code which is to be executed, when the form is submitted.
    # when the form is generated, and any JS code has been registered using
    # this function, an <code>OnSubmit</code> handler is dynamically generated 
    # where the code is placed.
    # <br><br>
    # The generated code looks like the following where stmt stands for the
    # registered statments
    #
    # @example
    # function _onSubmit() 
    # {
    #   return stmt1 &&
    #          stmt2 &&
    #          ...
    #          stmt#;
    # }
    #---------------------------------------------------------------------
    function OnSubmit($jscode)
    {
        $this->onsubmit[] = $jscode;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Sets the action URL for this form. This is the URL to which the
    # form data will be submitted. Usually, the URL is obtained by the
    # GetActionURL of the MIOLO class.
    #---------------------------------------------------------------------
    function SetAction($action)
    {
        $this->buttons[] = new FormButton( _M('Send'), FORM_SUBMIT_BTN_NAME, 'SUBMIT');
        $this->action = $action;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Sets an URL to a help document. This document will be opened via
    # JavaScript in a new window. If this URL is set, the form will display
    # a help button in it's title bar.
    #---------------------------------------------------------------------
    function SetHelp($href)
    {
        $this->help = $href;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Obtain the list of form fields.
    #
    # @deprecated this function will be changed in the near future, so
    # don't use it anymore and keep in touch with the development team
    # to figure out, what will be the replacement. 
    #
    # @returns (array) the list of form fields 
    #---------------------------------------------------------------------
    function /*PRIVATE*/ GetFields()
    {
        return $this->fields;
    }
    
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This function is used to set an array of fields for the form.
    #---------------------------------------------------------------------
    function SetFields(&$fields)
    {
        $this->fields = & $fields;

        $this->_RegisterField($this->fields);
    }
    
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This function is used internally of the form framework to 
    # <i>prepare</i> the form fields for the usage within the form
    # framework.
    # <br><br>
    # The function basically renames all fields to 'frm_' + name and
    # assigns the value from the global array <code>$_REQUEST</code>
    # if the field has no value (null) assigned.
    #
    # @param $field (reference) to a single field or an array of fields
    #               If an array of fields is passed, the function is called
    #               recursively for each of the contained fields.
    # 
    # @returns (nothing)
    #---------------------------------------------------------------------
    function /*PRIVATE*/ _RegisterField(&$field)
    {
        if ( is_array($field) )
        {
            for ( $i=0; $i<count($field); $i++ )
            {
                $this->_RegisterField($field[$i]);
            }
        }
        
        else
        {
            $field->form = & $this;
            
            if ( get_class( $field ) == 'filefield' )
            {
                $this->enctype='multipart/form-data';
            }
            
            if ( $field->name )
            {
                $field->name = 'frm_' . $field->name;

                if ( $field->value == '' )
                {
                    $class = get_class($field);
                    
                    if (  $class == 'checkbox' || $class == 'radiobutton' )
                    {
                        // set checked flag of checkbox or radiobutton if the value matches
                        $field->checked = (MIOLO::_REQUEST($field->name) == $field->value);
                    }
                    else
                    {
                        $field->value = MIOLO::_REQUEST($field->name);
                    }
                }
                    
                $field->value = $this->EscapeValue($field->value);
            }
        }
    }
    
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Adds a single field to the list of form fields and optionally adds
    # a hint text for the field.
    #
    # @param $field (reference) a reference to a form field object
    # @param $hint  (string)    an optional hint for the form field
    #
    # @returns (nothing)
    #---------------------------------------------------------------------
    function AddField(&$field,$hint=false)
    {
        if ( $hint )
        {
            $field->SetHint($hint);
        }
        
        $this->_RegisterField($field);
        
        $this->fields[] = $field;
    }
    
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Adds a form button. The button is added to the list of form buttons.
    # By default, the form framework arranges the buttons at the bottom
    # of the form container from the left to the right.
    #
    # @param $label  (string) the text which will appear on the button
    # @param $name   (string) the internal button name
    # @param $action (string) the action; 'SUBMIT', 'RESET' for the buttons
    #                         type attribute or a JavaScript instruction for
    #                         the button's onClick attribute
    # @see FormButton
    #---------------------------------------------------------------------
    function AddButton($label,$name,$action)
    {
        $this->buttons[] = new FormButton($label,$name,$action);
    }
    
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This function is mainly used, to change the labels of the form's
    # default buttons for submit and return.
    # @param $index (integer) the 0 based index of the button
    # @param $label (string) the new button label
    #---------------------------------------------------------------------
    function SetButtonLabel($index,$label)
    {
        $this->buttons[$index]->label = $label;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This function can be used to show or hide the form's return button.
    # @param $state (boolean) the visible state of the return button
    #---------------------------------------------------------------------
    function ShowReturn($state)
    {
        $this->return = $state;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This function can be used to show or hide the form's reset button.
    # @param $state (boolean) the visible state of the reset button
    #---------------------------------------------------------------------
    function ShowReset($state)
    {
        $this->reset = $state;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This function returns the visibility of the form's hint texts.
    # @see ShowHints
    #---------------------------------------------------------------------
    function GetShowHints()
    {
        return $this->showHints;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This function can be used to show or hide the form's hint texts.
    # Each form element may have a hint text associated with it. Using
    # this method, one can enable/disable the display of the texts. This
    # may be useful for implementing kind of an beginner/expert mode.
    # @param $state (boolean) the visible state of the hint texts
    #---------------------------------------------------------------------
    function ShowHints($state)
    {
        $this->showHints = $state;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This is a placeholder function to bu the form's field list. It
    # is excpected, that the form returns a scalar list of all defined 
    # fields which carry a form field value. Thus, form elements of 
    # decorative purpose only should be omitted.
    # <br><br>
    # Derived classes such as <code>TabbedForm</code> override this
    # function to provide the list of fields independently of the form's
    # layout.
    #---------------------------------------------------------------------
    function GetFieldList()
    {
        return $this->_GetFieldList($this->fields);
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Internal function which takes a list of form elements possibly
    # consisting of single fields as well as arrays and returns a scalar
    # the list of fields filtering out some known decorative form fields.
    # @param $allfields (array) an array of form fields
    # @returns (array) a scalar array of form fields
    #---------------------------------------------------------------------
    function /* PRIVATE */ _GetFieldList($allfields)
    {
        foreach ($allfields as $f )
        {
            if ( is_array($f) )
            {
                foreach ( $f as $a )
                {
                    if ( get_class($a) == 'separator' || get_class($a) == 'text')
                    {
                        continue;
                    }
                        
                    $fields[] = $a;
                }
            }
            else
            {
                if ( get_class($a) == 'separator'  || get_class($a) == 'text')
                {
                    continue;
                }
                    
                $fields[] = $f;
            }
        }
        
        return $fields;
    }
    
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Validates all form fields to have a non-empty content
    # @param $assert (boolean) flag how to handle invalid fields;<br>
    #                if true, an error message will be shown<br>
    #                if false no error message will be shown and the
    #                caller can provide an appropriate action based on the
    #                return value.
    # @returns (boolean) <b>true</b> if all fields have a value;
    #                    <b>false</b> if any of the fields has been left
    #                    empty
    #---------------------------------------------------------------------
    function ValidateAll($assert=true)
    {
        foreach ( $this->GetFieldList() as $f )
        {
            if ( $f->name )
            {
                $required[] = substr($f->name,4);
            }
        }
        
        return $this->Validate($required, $assert);
    }


    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Validates data for the form fields. The validation is based on the
    # parameter $required
    #
    # @param $required (array) Fields names wich should be validated
    #
    # @returns (boolean) <b>true</b> if the fields have a value;
    #                    <b>false</b> if any of the fields has been left
    #                    empty
    #---------------------------------------------------------------------
    function Validate($required,$assert=true)
    {   global $MIOLO;
        
        unset($this->errors);
        
        // collect fields by label
        foreach ( $this->GetFieldList() as $f )
        {
            $fields[$f->name] = $f->label;
        }
        
        foreach ( $required as $r )
        {
            $name  = "frm_$r";
            $label = $fields[$name];
            
            $MIOLO->Assert($label,
                           "ERROR: Required field [<b><font color=red>$name</font></b>] is not defined in form!");
            
            $value = $_REQUEST[$name];
            
            if ( $value === '' )
            {
                $this->errors[] = "<b>$label</b> " . _M("was not informed!");
            }
        }
       
        if ( $assert && count($this->errors) )
        {
            $theme =& $MIOLO->GetTheme();
            $theme->SetContent($this);
           
            $theme->Generate();
        }
       
        return count($this->errors) == 0;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # registrar um erro relacionado ao form
    #---------------------------------------------------------------------
    function Error($err)
    {   global $MIOLO;
        $MIOLO->LogMessage('[DEPRECATED] Call method Form::Error() is deprecated -- use Form::AddError() instead!');
        $this->AddError($err);
    }

    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # registrar um erro relacionado ao form
    #---------------------------------------------------------------------
    function AddError($err)
    {
        if ( $err )
        {
            if ( is_array($err) )
            {
                if ( $this->errors )
                {
                    $this->errors = array_merge($this->errors,$err);
                }
                
                else
                {
                    $this->errors = $err;
                }
            }
            
            else
            {
                $this->errors[] = $err;
            }
        }
    }

    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    #  returns the number of error messages or 0, if no errors exist
    #---------------------------------------------------------------------
    function HasErrors()
    {
        return count($this->errors);
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Get form data and put it into the class members
    #---------------------------------------------------------------------
    function CollectInput($data)
    {   global $MIOLO;
        
        echo "\n<!-- *** Collect Input ***\n";
        echo "//\n";
        echo "// Collect input of form {$this->name} \n";
        echo "//\n";
        
        foreach ( $this->GetFieldList() as $f )
        {
            // campo da classe de destino ? nome campo exceto prefixo 'frm_'
            $field = substr($f->name,4);
            
            if ( $field != '' )
            {
                echo "\$data->$field = \$_REQUEST['{$f->name}'];\n"; 
            
                eval("\$data->$field = \$_REQUEST['{$f->name}'];");
            }
        }
        
        echo "-->\n";
        
        return $data;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # obtains form fields in a FormData object
    #---------------------------------------------------------------------
    function GetData()
    {
        return $this->CollectInput(new FormData);
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Set form fields values. A subclassed form will likely override this
    # method, in order to provide a specialized processing for the passed
    # data object.
    # <br><br>
    # This method simply calls the <code>_SetData()</code> method of the
    # <code>Form</code> class.
    # @example
    # $data = new FormData();
    # $form->SetData($data);
    #---------------------------------------------------------------------
    function SetData($data)
    {
        $this->_SetData($data);
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # This method sets the form field values in way, that it iterates
    # thru the list of fields and sets the values of all fields matching
    # the data object attribute names.
    # <br><br>
    # In short it does the following<br>
    # <blockquote>
    # <code>$frm_name = $data->name;</code>
    # <blockquote>
    # This implies that the form field names must be identical the data
    # member names.
    #---------------------------------------------------------------------
    function /* private */ _SetData($data)
    {  
        for ( $i=0; $i<count($this->fields); $i++ )
        {
            // campo da classe de destino ? nome campo exceto prefixo 'frm_'
            $name = substr($this->fields[$i]->name,4);
            
            if ( $name )
            {
                if ( is_subclass_of($fields[$i],'radiobutton') || is_subclass_of($fields[$i],'checkbox') )
                {
                    eval('$this->fields[$i]->checked = ( $data->' . $name . ' == $this->fields[$i]->value );');
                }
                else
                {
                    eval('$this->fields[$i]->value = $data->' . $name .';');
                }
            }
        }
    }

    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # obtains a form field's value
    #---------------------------------------------------------------------
    function GetFieldValue($name,$value=false)
    {   
        $name = 'frm_' . $name;
        
        for ( $i=0; $i<count($this->fields); $i++ )
        {
            // campo da classe de destino ? nome campo exceto prefixo 'frm_'
            if ( $name == $this->fields[$i]->name )
            {
                return $this->fields[$i]->value;
            }
        }
        
        return $value;
    }

    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Set a form field's value
    #---------------------------------------------------------------------
    function SetFieldValue($name,$value)
    {   
        $name = 'frm_' . $name;
        
        for ( $i=0; $i<count($this->fields); $i++ )
        {
            // campo da classe de destino ? nome campo exceto prefixo 'frm_'
            if ( $name == $this->fields[$i]->name )
            {
                $this->fields[$i]->value = $value;
                break;
            }
        }
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Get a form field's value
    #---------------------------------------------------------------------
    function & GetField($name)
    {
        $name = 'frm_' . $name;
        
        for ( $i=0; $i<count($this->fields); $i++ )
        {
            // campo da classe de destino ? nome campo exceto prefixo 'frm_'
            if ( $name == $this->fields[$i]->name )
            {
                return $this->fields[$i];
            }
        }
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # generates the form's body and returns the resulting HTML code 
    #---------------------------------------------------------------------
    function GetBody()
    {
        ob_start();
        $this->GenerateBody();
        $body = ob_get_contents();
        ob_end_clean();
        return $body;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Generate entire input form
    #---------------------------------------------------------------------
    function Generate()
    {   global $MIOLO;
        
        // get the theme painter and draw the form
        $painter = & $MIOLO->GetThemePainter();
        $painter->GenerateForm($this);
        
        // scripts are always generated here, since they should not depend
        // of the applied theme
        //$this->GenerateScript();
    }
    
    //
    //
    //
    function GenerateErrors()
    {
        $caption = _M('Errors Occured');
        
        echo "  <table width=\"100%\" bgcolor=\"#c00000\" cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n" .
             "    <tr class=\"formErrors\">\n"  .
             "      <td width=\"60\" valign=\"top\"><div style=\"margin: 10px\"><img src=\"/images/error.gif\"></div></td>\n" .
             "      <td valign=\"top\"><font size=+1><b>$caption:</b></font>\n<ul>\n";
        
        foreach ( $this->errors as $e )
        {
            echo "        <li>$e</li>\n";
        }
        
        echo "      </ul></div></td>\n"  .
             "    </tr>\n"  .
             "  </table>\n";
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    #  Generate form body
    #---------------------------------------------------------------------
    function GenerateBody()
    {
        // optionally generate errors
        if ( $this->HasErrors() )
        {
            $this->GenerateErrors();
        }
        
        echo "<form name=\"$this->name\" method=\"$this->method\" action=\"$this->action\" ";
        if ( $this->enctype )
        {
            echo(" enctype=\"$this->enctype\" ");
        }
        echo " onSubmit=\"return {$this->name}_onSubmit();\" >\n";

        echo "<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n";
        
        $hidden = null;

        echo "  <tr>\n";
        echo "    <td colspan=\"2\" class=\"formBody\">\n";
        
        $this->LayoutFormFields($this->fields,&$hidden);
        
        echo "    </td>\n";
        echo "  </tr>\n";
            
        echo "  <tr>\n";
        echo "    <td colspan=\"2\"><hr size=\"1\" noshade></td>\n";
        echo "  </tr>\n";
        echo "  <tr>\n";
        echo "    <td colspan=\"2\">\n";
        echo "<blockquote>&nbsp;";
        
        if ( $this->buttons )
        {
            foreach ( $this->buttons as $b )
            {
                $b->Generate();
            }
        }
        
        if ( $this->reset )
        {
            echo "      <input type=\"reset\">\n";
        }
        
        if ( $this->return )
        {
            echo "      <input name=\"return\"  type=\"button\" value=\"Retornar\" onclick=\"javascript:history.go(-1)\">\n";
        }
        
        echo "</blockquote>";
        echo "    </td>\n";
        echo "  </tr>\n";
        echo "</table>\n";
        
        if ( $hidden )
        {
            echo "      <!-- START OF HIDDEN FIELDS -->\n";
            
            foreach ( $hidden as $h )
            {
                echo "      ";
                $h->Generate();
                echo "\n";
            }
            
            echo "      <!-- END OF HIDDEN FIELDS -->\n";
        }
        
        echo "</form>\n";
        
        $this->GenerateScript();
    }

    function SetFocus($field)
    {
        $this->focus = $field;
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    #  Generate form specific script code
    #---------------------------------------------------------------------
    function GenerateScript()
    {
        // we generate the form onSubmit handler right in the body of the form
        echo "<!-- START OF FORM SCRIPT CODE -->\n";
        echo "<script language=\"JavaScript\">\n";
        if ($this->focus)
        {
            echo "document.{$this->name}['frm_{$this->focus}'].focus();\n";
        }
        else
        {
            echo "document.{$this->name}.elements[0].focus();\n";
        }

        if ( $this->validations )
        {
            echo "\n";
            echo "/**\n";
            echo " * MIOLO Form Validation Objects\n";
            echo " */\n";
            foreach ( $this->validations as $v )
            {
                $v->Generate();
                echo "\n";
            }
            echo "var {$this->name}_validations = Array( ";
            $i = 0;
            foreach ( $this->validations as $v )
            {
                if ( $i++ )
                {
                    echo ",\n                                ";
                }
                echo $v->name;
            }
            echo " );\n";
            echo "\n";
        }
        
        echo "/**\n";
        echo " * MIOLO Form Submit Handler\n";
        echo " */\n";
        echo "function {$this->name}_onSubmit()\n";
        echo "{\n";
        echo "  return true";  // no new line - statement is terminated below!

        if ( $this->onsubmit )
        {
          foreach ( $this->onsubmit as $s )
          {
              echo " &&\n         ( $s )";
          }
        }
        echo ";\n";           // terminate return statement here
        echo "}\n";
        echo "</script>\n";
        echo "<!-- END OF FORM SCRIPT CODE -->\n";
    }
    
    #+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
    # Do Layout of (visible) fields within form area
    #---------------------------------------------------------------------
    function LayoutFormFields($fields,&$hidden)
    {
        echo "<table>\n";
        
        if ( is_array($fields) )
        {
            foreach ( $fields as $f )
            {
                if ( ! is_array($f) )
                {
                    if ( get_class($f) == 'separator' || get_class($f) == 'text')
                    {
                        echo "  <tr>\n";
                        echo "    <td class=\"formLabel\" colspan=\"3\">";
                        
                        $f->Generate();
                        
                        echo "</td>\n";
                        echo "  </tr>\n";
                    }
                    else
                    {
                        // this is necessary, because the backreference gets somehow lost
                        $f->form = & $this;
                        
                        // if field does not have a label, consider it a hidden field
                        if ( ! $f->label )
                        {
                            $hidden[] = $f;
                            continue;
                        }
                        
                        echo "  <tr>\n";
                        
                        $label = $f->label;
                        
                        if ( $label != '' && $label != '&nbsp;' )
                        {
                            $label .= ':';
                        }
                        
                        echo "    <td class=\"formLabel\" valign=\"top\" nowrap>&nbsp;$label&nbsp;</td>\n";
                        echo "    <td _width=\"100%\" valign=\"top\">";
                        
                        $f->Generate();
                        
                        echo "</td>\n";
                        
                        if ( $this->showHints && $f->hint )
                        {
                            echo "    <td class=\"formHint\" valign=\"top\">{$f->hint}</td>\n";
                        }
                        
                        echo "  </tr>\n";
                    }
                }
                
                // we have an array of form fields, which are spread horizontally
                else
                {
                    $num_hints = 0;
                    
                    echo "  <tr>\n";
                    echo "    <td colspan=\"2\">\n";
                    echo "      <table>\n";
                    echo "        <tr>\n";
                        
                    foreach ( $f as $c )
                    {
                        // if field does not have a label, consider it a hidden field
                        if ( ! $c->label )
                        {
                            continue;
                        }
                        
                        $label = $c->label;
                        
                        if ( $label != '&nbsp;' )
                        {
                            $label .= ':';
                        }
                        
                        echo "    <td class=\"formLabel\" valign=\"top\" nowrap>&nbsp;$label&nbsp;</td>\n";
                        
                        if ( $f->hint )
                        {
                            $num_hints++;
                        }
                    }
                    
                    echo "        </tr>\n";
                    echo "        <tr>\n";
                    
                    foreach ( $f as $c )
                    {
                        // this is necessary, because the backreference gets somehow lost
                        $c->form = & $this;
                        
                        // if field does not have a label, consider it a hidden field
                        if ( ! $c->label )
                        {
                            $hidden[] = $c;
                            continue;
                        }
                        
                        echo "    <td valign=\"top\">";
                        
                        $c->Generate();
                        
                        echo "</td>\n";
                    }
                    
                    echo "        </tr>\n";
                    
                    if ( $this->showHints && $num_hints )
                    {
                        echo "        <tr>\n";
                        
                        foreach ( $f as $c )
                        {
                            if ( $f->hint )
                            {
                                echo "    <td class=\"formHint\" valign=\"top\">{$f->hint}</td>\n";
                            }
                            else
                            {
                                echo "    <td>&nbsp;</td>\n";
                            }
                        }
                        
                        echo "        </tr>\n";
                    }
                    
                    echo "      </table>\n";
                    echo "    </td>\n";
                    echo "  </tr>\n";
                }
            }
        }
        
        echo "</table>\n";
    }
}


#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
#  pseudo class to collect form field values
#---------------------------------------------------------------------
class FormData
{
}

// ----------------------------------------------------------------------
//
// ----------------------------------------------------------------------
class FormField
{
    var $form;   // back reference to form object
    var $label;
    var $name;
    var $value;
    var $hint;
    var $attrs;
    
    function FormField($label,$name,$value=null,$hint='')
    {
        $this->label  = $label;
        $this->name   = $name;
        $this->value  = $value;
        $this->hint   = $hint;
    }
    
    function GetHint($hint)
    {
        return $this->hint;
    }
    
    function SetHint($hint)
    {
        $this->hint = $hint;
    }
    
    function AddAttribute($name,$value)
    {
        $this->attrs[] = array($name,$value);
    }
    
    function Generate()
    {
        if ( ( ! is_subclass_of($this,'separator') ) && ( ! is_subclass_of($this,'text') ) )
        {
            if ( $this->label )
            {
                echo $this->value;
            }

            $a = $this->Attributes();
            
            echo "<input name=\"$this->name\" type=\"hidden\" value=\"$this->value\" $a>";
        }
    }
    
    function Attributes()
    {
        if ( count($this->attrs) )
        {
            foreach($this->attrs as $a)
            {
                if ( $s )
                {
                    $s .= ' ';
                }
                
                $s .= $a[0] . '="' . $a[1] . '"'; 
            }
        }
        
        return $s;
    }
}

// ----------------------------------------------------------------------
//
// ----------------------------------------------------------------------
class FormButton extends FormField
{
    var $label;
    var $name;
    var $action;
    
    function FormButton($label,$name,$action)
    {
        $this->label  = $label;
        $this->name   = $name;
        $this->action = $action;
    }
    
    function Generate()
    {
        $html = "      <input name=\"$this->name\"";
        
        if ( strtoupper($this->action) == 'SUBMIT' )
        {
            $html .= "  type=\"submit\"";
        }
        else if ( strtoupper($this->action) == 'RESET' )
        {
            $html .= "  type=\"reset\"";
        }
        else
        {
            $html .= "  type=\"button\" onclick=\"$this->action\"";
        }
        
        if ( $this->label )
        {
            $html .= "  value=\"$this->label\"";
        }
        
        $html .= $this->Attributes();
        
        $html .= ">\n";
        
        echo $html;
    }
}

