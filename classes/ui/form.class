#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
#  A general purpose class for Options for usage with CheckboxGroup,
#  RadioButtonGroup and Selection
#---------------------------------------------------------------------
class Option
{
    var $label;
    var $name;
    var $value;
    var $checked;
    
    function Option($label,$name,$value=null,$checked=false,$id=false)
    {
        $this->label   = $label;
        $this->name    = $name;
        $this->value   = $value;
        $this->checked = $checked;
    }
}

#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
#  Implements a group of checkboxes 
#---------------------------------------------------------------------
class CheckBoxGroup extends FormField
{
    var $options;
    
    function CheckBoxGroup($label,$name,$options,$hint='')
    {
        $this->FormField($label,$name,false,$hint);
        
        $this->options = $options;
    }

    function Generate()
    {
        $n = count($this->options);
        
        for ($i=0; $i<$n; $i++ )
        {
            if ( $i )
            {
                echo "&nbsp;&nbsp;&nbsp;";
            }
            
            // we will accept an array of Options ... 
            if ( is_subclass_of($this->options[$i],'option') ||
                 get_class($this->options[$i]) =='option'
                )
            {           
                $name    = $this->name . '_' . $this->options[$i]->name;
            
                $label   = $this->options[$i]->label;
                $value   = $this->options[$i]->value;
                
                $checked = $this->options[$i]->checked ||
                           $value == $_REQUEST[$name];
            }
            // or an array of key/value pairs ... 
            else if ( is_array($this->options[$i]) )
            {
                $name = $this->name . '_' . $i;
            
                $label   = $this->options[$i][0];
                $value   = $this->options[$i][1];
                
                $checked = $value == $_REQUEST[$name];
            }
            // or a simple array of values
            else
            {
                $name = $this->name . '_' . $i;
            
                $label   = $value = $this->options[$i];
                
                $checked = $value == $_REQUEST[$name];
            }
            
            echo "<input name=\"$name\" type=\"checkbox\" value=\"$value\"";
            
            if ( $checked )
            {
                echo ' checked';
            }
            
            echo ">&nbsp;" . $label;
        }
    }
}

#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Implements a group of radio buttons 
#---------------------------------------------------------------------
class RadioButtonGroup extends FormField
{
    var $options;
    var $default;
    var $layout = 'horizontal';
    var $value;
    
    function RadioButtonGroup($label,$name,$options,$default=false,$hint='')
    {
        $this->FormField($label,$name,false,$hint);
        
        $this->options = $options;
        $this->default = $default;
        
        $this->value = Form::GetFormValue($name, $default);
    }
    
    function SetVerticalLayout()
    {
        $this->layout = 'vertical';
    }
    
    function SetHorizontalLayout()
    {
        $this->layout = 'horizontal';
    }
    
    function Generate()
    {
        $n = count($this->options);
        
        switch($this->layout)
        {
            case 'vertical':
                 $break = '<br>';
                 break;
                 
            case 'horizontal':
            default:
                 $break = '&nbsp;&nbsp;&nbsp;';
                 break;
        }

        for ($i=0; $i<$n; $i++ )
        {
            if ( $i )
            {
                echo $break;
            }
            
            $name = $this->name;
            
            if ( is_subclass_of($this->options[$i],'option') ||
                 get_class($this->options[$i]) =='option'
                )
            {
                $label   = $this->options[$i]->label;
                $value   = $this->options[$i]->value;
                
                $checked = $value == $this->value ||
                           $this->options[$i]->checked;
            }
            else if ( is_array($this->options[$i]) )
            {
                $label   = $this->options[$i][0];
                $value   = $this->options[$i][1];
                $checked = $value == $this->value;
            }
            else
            {
                $label   = $value = $this->options[$i];
                $checked = $value == $this->default ||
                           $value == $_REQUEST[$name];
            }
            
            echo "<input name=\"$name\" type=\"radio\" value=\"$value\"";
            
            if ( $checked )
            {
                echo ' checked';
                
            }
            
            echo ">&nbsp;" . $label;
        }
    }
}

// ----------------------------------------------------------------------
//
// ----------------------------------------------------------------------
class Selection extends FormField
{
    var $options;
    var $showValues;
    var $autoSubmit;
    
    function Selection($label,$name,$value,$options='',$showValues=false,$hint='')
    {
        if ( ! $options )
        {
            $options = Array(_M('No'),_M('Yes'));
        }
        
        $this->FormField($label,$name,$value,$hint);
        $this->options = $options;
        $this->showValues = $showValues;
    }
    
    function SetAutoSubmit($state)
    {
        $this->autoSubmit = $state;
    }
    
    //
    //
    //
    function Generate()
    {   global $MIOLO;
        
        $selected = false;
        
        if ( $this->autoSubmit )
        {
            $this->AddAttribute('onChange','document.' . $this->form->GetName() . '.submit()');
        }
        
        $a = $this->Attributes();
        
        echo "<select name=\"$this->name\" $a>\n";
        
        foreach( array_keys($this->options) as $k )
        {            
            $o = $this->options[$k];
            
            if ( is_array($o) ) 
            {
                list ($id, $name) = $o;
                
                if ( $this->showValues )
                {
                    // show '#' instead of space 
                    $name = ($id==' '&&$id!='0'?'#':$id) . ' - ' . $name; 
                }
                
                echo "<option value=\"$id\"";
            
                if ( $id == $this->value && ! $selected )
                {
                    echo ' selected';
                    
                    $selected = true;
                }
                
                echo ">$name</option>\n";
            }
            else
            {
                if ( $this->showValues )
                {
                    // show '#' instead of space 
                    $o = ( ( $k == ' ' ) && ( $k != '0' ) ? '#' : $k ) . ' - ' . $o;
                }
                
                echo "<option value=\"$k\"";
            
                if ( $k == $this->value && ! $selected )
                {
                    echo ' selected';
                    
                    $selected = true;
                }
            
                echo ">$o</option>\n";
            }
        }
        
        echo "</select>\n";
    }
}

// ----------------------------------------------------------------------
//
// ----------------------------------------------------------------------
class MultiSelection extends FormField
{       
    var $options;
    var $showValues;
    
    function MultiSelection($label='&nbsp;', $name, $values=Array('1','2','3'),
$options=Array('Option1','Option2','Option3'), $showValues=false, $hint='', $size='')
    {
        //if ( !is_array($values) )
        //   echo "<font color='red'><b>\$values<b> must be an single-dimensional array</font>";
           
        //if ( !is_array($options) )
        //   echo "<font color='red'><b>\$options<b> must be an {single,multi}-dimensional array</font>";
           
        $this->FormField($label,$name,$values,$hint);
        $this->options    = $options;
        $this->showValues = $showValues;
        $this->size       = $size;
        $this->value      = $values; // is this still necessary?
    }


   
    //
    //
    //
    function Generate()
    {   global $MIOLO;
        echo "\n<select multiple size=\"$this->size\" name=\"{$this->name}[]\" ";
        echo $this->Attributes();
        echo ">\n";

        foreach( array_keys($this->options) as $k )
        {
            $o = $this->options[$k];
	    if ( is_array($o) )
	    {
                list ($id, $opt) = $o;
	    }
	    else
	    {
	        $id = $k;
                $opt = $o;
	    }

            if ( $this->showValues )
            {
                // show '#' instead of space
                $opt = ($id==' '&&$id!='0'?'#':$id) . ' - ' . $opt;
            }

            echo "<option value=\"$id\"";

            $found = array_search($id,$this->value);
            if ( (!is_null($found)) && ($found !== false) ) echo ' selected';

            echo ">$opt</option>\n";
        }

        echo "</select>\n";
    }
}


/**
 *
 */
class ComboBox extends FormField
{
    var $options;
    var $autoSubmit;

    function SetAutoSubmit($state)
    {
        $this->autoSubmit = $state;
    }

    function ComboBox($label,$name,$value,$options,$hint='')
    {
        $this->FormField($label,$name,$value,$hint);

        $this->options = $options;

        reset($this->options);

        $o = current($this->options);

        // array multi-dimensional (result from db query) 
        if ( is_array($o) )
        {
        $default = array('','--- ' . _M('Select') . ' ---');

        $this->options = array_merge(array($default),$this->options);
        }

        // simple array 
        else
        {
        $default = array('' => '--- ' . _M('Select') . ' ---');

        $this->options = array_merge($default,$this->options);
        }
    }

    function Generate()
    { global $MIOLO;

        echo "<input name=\"{$this->name}\" type=\"text\" size=\"6\"".
        " value=\"{$this->value}\"";
        if ( $this->autoSubmit )
        echo " onChange=\"ComboBox_onTextChange('{$this->label}',this.form.elements['{$this->name}_sel'],this.form.elements['{$this->name}_sel']);document." . $this->form->GetName() . ".submit();\"> ";
        else
        echo " onChange=\"ComboBox_onTextChange('{$this->label}',this.form.elements['{$this->name}'],this.form.elements['{$this->name}_sel'])\">";

        echo "&nbsp;";
        echo "<select name=\"{$this->name}_sel\"";
        if ( $this->autoSubmit )
        echo " onChange=\"ComboBox_onSelectionChange('{$this->label}',this.form.elements['{$this->name}_sel'],this.form.elements['{$this->name}']);document." . $this->form->GetName() . ".submit();\"> ";
        else
        echo " onChange=\"ComboBox_onSelectionChange('{$this->label}',this.form.elements['{$this->name}_sel'],this.form.elements['{$this->name}'])\"> ";

        foreach( array_keys($this->options) as $k )
        {      
        $o = $this->options[$k];

        if (is_array($o)) 
        {
            list ($id, $name) = $o;

            if ( strlen($name) > 40 )
            {
            $name = substr($name,0,37) . '...';
            }

            echo "<option value=\"$id\"";

            if ( "$id" == "{$this->value}" )
            {
            echo ' selected';
            }

            echo ">$name</option>\n";
        }

        else
        {
            echo "<option value=\"$k\"";

            if ( "$k" == "{$this->value}" )
            {
            echo ' selected';
            }

            echo ">$o</option>\n";
        }
        }

        echo "</select>\n";
    }
}


#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
#
#---------------------------------------------------------------------
class LookupField extends FormField
{
    var $action;
    var $related;
    var $module;
    var $item;
    var $info;
    var $defaults;
    
    function LookupField($label,$name,$related,$module,$item,$value='',$hint='',$defaults=array())
    {   global $MIOLO;
        
        $this->FormField($label,$name,$value,$hint);
        $this->related = $related;
        $this->module  = $module;
        $this->item    = $item;
        $this->defaults = $defaults;
        
        if ( $value )
        { 
            // $this->info = $MIOLO->GetAutoComplete($module,$item,$value);
        }
    }
    
    function Generate()
    {   global $MIOLO;
        
        $lookup_name = "lookup_{$this->form->name}_{$this->name}";
        
        $related = is_array($this->related) ? $this->related : array($this->related);
        
        echo "<script language=\"JavaScript\">\n";
        echo "    var $lookup_name = new LookupContext();\n";
        echo "    $lookup_name.module  = '{$this->module}';\n";
        echo "    $lookup_name.item    = '{$this->item}';\n";
        echo "    $lookup_name.related = '" . implode(',',$related) . "';\n";
        echo "    $lookup_name.form    = document.{$this->form->name};\n";
        echo "    $lookup_name.field   = '{$this->name}';\n";
        echo "    document.lookup = $lookup_name;\n";
 
        if(is_array($this->defaults))
        {
            $i = 0;
            echo "    $lookup_name.defaults = new Array();\n";
            foreach($this->defaults as $id=>$value)
            {
                $defaults[$id] = $this->form->GetFieldValue($value);
                echo "    $lookup_name.defaults[$i] = new Array('$id','$value');\n";
                $i++;
            }
        }

        echo "</script>\n";
        echo "<table cellspacing=\"0\" cellpadding=\"0\" border=\"0\">\n";
        echo "  <tr>\n";
        echo "    <td>\n";
        echo "      <input name=\"{$this->name}\" type=\"text\" size=\"8\" onBlur=\"MIOLO_AutoComplete($lookup_name)\" value=\"$this->value\">\n";
        echo "    </td>\n";
        echo "    <td>\n";
        echo "      <input type=\"button\" value=\"...\" onClick=\"MIOLO_Lookup($lookup_name)\">\n";
        echo "    </td>\n";
        echo "  </tr>\n";
        echo "</table>\n";
        
        $rs = $MIOLO->AutoComplete($this->module,$this->item,$this->value,$defaults);
        
        if ( $rs )
        {
            $i = 0;
            
            foreach ( $related as $r )
            {
                $this->form->SetFormValue($r,$rs[$i++]);
            }
        }
    }
}

#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Implements input field, which can have multiple input values
# relies on _MIOLO_MultiTextField_*() JavaScript support
#---------------------------------------------------------------------
class MultiTextField extends FormField
{
    var $buttons;
    
    function MultiTextField($label,$name,$width=200,$value=null,$buttons=false,$hint='')
    {
        $this->FormField($label,$name,$value,$hint);
        
        $this->width   = $width;
        $this->buttons = $buttons;
    }
    
    function Generate()
    {
        $this->form->OnSubmit("_MIOLO_MultiTextField_onSubmit('{$this->form->name}','{$this->name}')");
        
        echo "  <table border=\"0\" cellspacing=\"0\" cellpadding=\"2\">\n";
        echo "    <tr> \n";
        echo "      <td width=\"212\"> \n";
        echo "        <select name=\"{$this->name}[]\" size=\"3\" cols=\"40\" style=\"width:{$this->width};\" multiple onKeyDown=\"return _MIOLO_MultiTextField_onKeyDown(this,this.form,'{$this->name}',event);\">\n";
        
        if ( is_array($this->value) )
        {
            foreach ( $this->value as $v )
            {
                echo "<option>$v</option>\n";
            }
        }
        
        echo "        </select>\n";
        echo "      </td>\n";
        
        if ( $this->buttons )
        {
            echo "      <td width=\"90\" valign=\"top\">\n";
            echo "        <input type=\"button\" name=\"{$this->name}_remove\" value=\"Remover\" style=\"width:80;\" onClick=\"_MIOLO_MultiTextField_remove(this.form,'{$this->name}')\">\n";
            echo "      </td>\n";
        }
        
        echo "    </tr>\n";
        echo "    <tr> \n";
        echo "      <td width=\"212\"> \n";
        echo "        <input type=\"text\" name=\"{$this->name}_text\" style=\"width:{$this->width};\" onKeyDown=\"return _MIOLO_MultiTextField_onKeyDown(this,this.form,'{$this->name}',event)\">\n";
        echo "      </td>\n";
        
        if ( $this->buttons )
        {
            echo "      <td width=\"90\"> \n";
            echo "        <input type=\"button\" name=\"{$this->name}_add\" value=\"Adicionar\" style=\"width:80;\" onClick=\"_MIOLO_MultiTextField_add(this.form,'{$this->name}')\">\n";
            echo "      </td>\n";
        }
        
        echo "    </tr>\n";
        echo "  </table>\n";
    }
}


#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# Implements input field, which can have multiple input values
# relies on _MIOLO_MultiTextField_*() JavaScript support
#---------------------------------------------------------------------
class MultiTextField2 extends FormField
{
    var $buttons;
    var $fields;
  
    function MultiTextField2($label,$name,$fields,$width=200,$value=null,$buttons=false,$hint='')
    {
        $this->FormField($label,$name,$value,$hint);
    
        $this->fields  = $fields;
        $this->width   = $width;
        $this->buttons = $buttons;
    }

    //
    //
    //  
    function Generate()
    {
        $n = count($this->fields);
        
        $this->form->OnSubmit("_MIOLO_MultiTextField_onSubmit('{$this->form->name}','{$this->name}')");
        
        echo "  <table border=\"0\" cellspacing=\"0\" cellpadding=\"2\">\n";
        echo "    <tr> \n";
        echo "      <td width=\"212\"> \n";
        echo "        <select name=\"{$this->name}[]\" size=\"3\" cols=\"40\" style=\"width:{$this->width};\" multiple onKeyDown=\"return _MIOLO_MultiTextField_onKeyDown(this,this.form,'{$this->name}',event,$n);\">\n";
        
        if ( is_array($this->value) )
        {
            foreach ( $this->value as $v )
            echo "<option>$v</option>\n";
        }
        
        echo "        </select>\n";
        echo "      </td>\n";
        
        if ( $this->buttons )
        {
            echo "      <td width=\"90\" valign=\"top\">\n";
            echo "        <input type=\"button\" name=\"{$this->name}_remove\" value=\"Remove\" style=\"width:80;\" onClick=\"_MIOLO_MultiTextField_remove(this.form,'{$this->name}')\"><br>\n";
            echo "        <input type=\"button\" name=\"{$this->name}_add\" value=\"Add\" style=\"width:80;\" onClick=\"_MIOLO_MultiTextField_add(this.form,'{$this->name}',$n)\">\n";
            echo "      </td>\n";
        }
        
        echo "    </tr>\n";
        
        foreach($this->fields as $f)
        {
            echo "    <tr> \n";
            echo "      <td width=\"212\">\n";
            echo "        <font size=\"1\">$f</font><br>\n";
            echo "        <input type=\"text\" name=\"{$this->name}_text$n\" style=\"width:{$this->width};\" onKeyDown=\"return _MIOLO_MultiTextField_onKeyDown(this,this.form,'{$this->name}',event,$n)\">\n";
            echo "      </td>\n";
            echo "    </tr>\n";
        }
        
        echo "  </table>\n";
    }
}


class FileField extends FormField
{
    var $size;
    
    function FileField($label,$name,$value,$size=40,$hint='')
    {
        
        $this->FormField($label,$name,$value,$hint);
        
        $this->size = $size;
        
    }
    
    function Generate()
    {
        echo("<input name=\"$this->name\" type=\"file\" value=\"$this->value\" size=\"$this->size\">");
    }
}


class RadioButton extends FormField
{
    var $checked;
    var $text;

    function RadioButton($label,$name,$value,$checked=false,$text=null,$hint='')
    {
        $this->FormField($label,$name,$value,$hint);

        $this->checked = $checked;
        $this->text    = $text;

    }

    function Generate()
    {
        echo("<input name=\"$this->name\" type=\"radio\" value=\"$this->value\"");

        if ( $this->checked )
        {
            echo(' checked');
        }

        echo('>');

        if ( $this->text )
        {
            echo("&nbsp;$this->text");
        }
    }
}


class DateField extends FormField
{
    var $size;
    var $type;
    var $validator;
    var $separator;
    var $style;

    function DateField($label,$name,$value='',$size=10,$hint='',$style='DMY',$separator='/')
    {
        $this->FormField($label,$name,$value,$hint);

        $tr = array('/'=>$separator,'-'=>$separator);
        
        $this->size = $size;
        $this->type = $size ? 'text' : 'hidden';
        
        eval("\$this->validator =  Validator::DATE{$style}Validator('optional',\$separator);");
        
        $this->separator = $separator;
        $this->value = strtr($value,$tr);
        $thos->style = $style;
    }

    function Generate()
    {   global $MIOLO;
        
        if ( $this->label && $this->type=='hidden' )
        {
            echo $this->value;
        }
        
        echo "<input name=\"$this->name\" type=\"$this->type\" value=\"$this->value\" "; 
        
        if ( $this->type=='text' && $this->size )
        {
            echo " size=\"$this->size\" ";
        }
        
        if ( $this->validator )
        {
            if ( $this->validator->type == 'readonly' )
            {
                echo " readonly style=\"color:blue;\" ";
            }
            elseif ( $this->validator->type == 'disable' )
            {
                echo " disabled style=\"color:blue;\" ";
            }
            else
            {
                $obj = $this->form->AddValidation($this);
                
                if ( $this->validator->mask )
                {
                    echo " onKeyPress=\"return MIOLO_Validate_Mask($obj,event)\" ";
                }
            }
        }
        
        echo $this->Attributes();
        
        echo ">\n";

        $url = "calendar.php?form={$this->form->name}&field={$this->name}&sep={$this->separator}";
        
        echo "<input type=button onClick=window.open('$url&date='+document.{$this->form->name}.{$this->name}.value,'','height=360,width=360,toolbar=no,location=no,directories=no,status=no,menubar=no,scrollbars=no,resizable=yes') value='...'>";
    }
}


#+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++
# @title
# MultiChoice.class
#
# @created
# 05/08/2004
#
# @organisation
# SOLIS - Cooperativa de Soluções Livres
#
# @legal
# CopyLeft (L) 2004 SOLIS
# Licensed under GPL (for further details read the
# LICENSE file)
#
# @contributors
# Daniel Afonso Heisler [dah] [daniel@solis.coop.br]
# Mauricio de Castro [mcastro] [mcastro@solis.coop.br]
#
#---------------------------------------------------------------------
class MultiChoiceField extends FormField
{
    var $buttons;

    function MultiChoiceField($label,$name,$width=200,$options=null,$values=null,$hint=null)
    {
        $this->FormField($label,$name,null,$hint);

        if ( $values )
        {
            foreach ( $values as $row )
            {
                foreach ( $options as $id => $row2 )
                {
                    if ( $row == $row2 )
                    {
                        $aux[$id] = $row2;
                        break;
                    }
                }
            }
        }
        $values = $aux;

        $this->values  = $values ? $values : array(null);
        $this->options = array_diff_assoc($options,$this->values);
        $this->width   = $width;

    }

    function Generate()
    {

        $this->form->OnSubmit("_MIOLO_MultiTextField_onSubmit('{$this->form->name}','{$this->name}')");

        // BEGIN JAVASCRIPT
        echo "<script language=\"JavaScript\">";
        echo "function _add() {";
        echo "    var opt_field = document.{$this->form->name}['{$this->name}_[]'];";
        echo "    var val_field = document.{$this->form->name}['{$this->name}[]'];";
        echo "    var opt = opt_field.selectedIndex+1;";
        echo "    if ( opt ) { ";
        echo "        aux = opt_field.options[opt-1];";
        echo "        val_field.options[val_field.options.length] = new Option(aux.text);";
        echo "        val_field.options[val_field.options.length-1].value = aux.value;";
        echo "        opt_field.options[opt-1] = opt_field.options[''];";
        echo "    }";
        echo "}";
        echo "function _del() {";
        echo "    var val_field = document.{$this->form->name}['{$this->name}[]'];";
        echo "    var opt_field = document.{$this->form->name}['{$this->name}_[]'];";
        echo "    var val = val_field.selectedIndex+1;";
        echo "    if ( val ) { ";
        echo "        aux = val_field.options[val-1];";
        echo "        opt_field.options[opt_field.options.length] = new Option(aux.text);";
        echo "        opt_field.options[opt_field.options.length-1].value = aux.value;";
        echo "        val_field.options[val-1] = val_field.options[''];";
        echo "    }";
        echo "}";
        echo "function _up() {";
        echo "    var field = document.{$this->form->name}['{$this->name}[]'];";
        echo "    var i = field.selectedIndex;";
        echo "    if (i){ ";
        echo "        var x;";
        echo "        var matrix = new Array(field.options.length);";
        echo "        for(x=0;x<=field.options.length;x++)";
        echo "            matrix[x] = field.options[x];";
        echo "        for(x=0;x<=field.options.length;x++) {";
        echo "            if ( x == i ) {";
        echo "                field.options[i-1] = matrix[i];";
        echo "                field.options[i] = matrix[i-1];";
        echo "            } else if ( x != (i-1) ) {";
        echo "                field.options[x] = matrix[x]";
        echo "            }";
        echo "        }";
        echo "    }";
        echo "}";
        echo "function _down() {";
        echo "    var field = document.{$this->form->name}['{$this->name}[]'];";
        echo "    var i = field.selectedIndex;";
        echo "    var x;";
        echo "    var matrix = new Array(field.options.length);";
        echo "    for(x=0;x<=field.options.length;x++)";
        echo "        matrix[x] = field.options[x];";
        echo "    for(x=0;x<=field.options.length;x++) {";
        echo "        if ( x == i ) {";
        echo "            if ( (x+1) < field.options.length ) {";
        echo "                field.options[x] = matrix[x+1];";
        echo "                field.options[x+1] = matrix[x];";
        echo "            }";
        echo "        } else if ( x != (i+1) ) {";
        echo "            field.options[x] = matrix[x]";
        echo "        }";
        echo "    }";
        echo "}";
        echo "</script>";
        // END JAVASCRIPT

        //SELECTION 1
        echo "  <table border=\"0\" cellspacing=\"0\" cellpadding=\"2\">\n";
        echo "    <tr> \n";
        echo "      <td width=\"*\"> \n";
        echo "        <select name=\"{$this->name}_[]\" size=\"5\" cols=\"20\" style=\"width:{$this->width};\" multiple onKeyDown=\"return _MIOLO_MultiTextField_onKeyDown(this,this.form,'{$this->name}',event);\">\n";

        if ( is_array($this->options) )
        {
            foreach ( $this->options as $id=>$v )
            {
                if ( trim($v) )
                {
                    if( !$id )
                    {
                        $id = $v;
                    }
                    echo "<option value='$id'>$v</option>\n";
                }
            }
        }
        echo "        </select>\n";
        echo "      </td>\n";

        //SELECTION 2
        echo "      <td width=\"212\"> \n";
        echo "        <select name=\"{$this->name}[]\" size=\"5\" cols=\"20\" style=\"width:{$this->width};\" multiple onKeyDown=\"return _MIOLO_MultiTextField_onKeyDown(this,this.form,'{$this->name}',event);\">\n";

        if ( is_array($this->values) )
        {
            foreach ( $this->values as $id=>$v )
            {
                if (trim($v))
                {
                    if ( !$id )
                    {
                        $id = $v;
                    }
                    echo "<option value='$id'>$v</option>\n";
                }
            }
        }
        echo "        </select>\n";
        echo "      </td>\n";
        echo "      <td width=\"30\" align=\"center\" valign=\"top\">\n";
        echo "        <br><input type=\"button\" name=\"{$this->name}_up\" value=\"Up\" style=\"width:50;\" onClick=\"_up()\">\n";
        echo "        <input type=\"button\" name=\"{$this->name}_down\" value=\"Down\" style=\"width:50;\" onClick=\"_down()\">\n";
        echo "      </td>\n";
        echo "    </tr>\n";
        echo "    <tr>\n";
        echo "      <td width=\"90\" align=\"center\" valign=\"top\">\n";
        echo "        <input type=\"button\" name=\"{$this->name}_add\" value=\"Add\" style=\"width:80;\" onClick=\"javascript:_add()\">\n";
        echo "      </td>\n";
        echo "      <td width=\"90\" align=\"center\" valign=\"top\">\n";
        echo "        <input type=\"button\" name=\"{$this->name}_remove\" value=\"Remove\" style=\"width:80;\" onClick=\"_del()\">\n";
        echo "      </td>\n";
        echo "    </tr>\n";
        echo "  </table>\n";

    }
}


?>
