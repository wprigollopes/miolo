$MIOLO = MIOLO::getInstance();
$MIOLO->page->addScript('m_expanddiv.js');

class MExpandDiv extends MDiv 
{
    public function __construct($name, $content, $class = NULL, $attributes = NULL)
    {
        // Removes line breaks from the beginning and the end of the content
        // and then change them to <br />
        $content = nl2br( trim( (string) $content ) );

        $id = $name ? "{$name}box" : 'box' . rand();

        // Button to expand the div
        $expandButton = new MDiv("{$id}Button", '', 'm-expand-div-button m-expand-div-button-collapsed');
        $expandButton->setBoxAttributes(array(
            'onclick' => "mexpanddiv.expand('{$id}');"
        ));

        // Div with the content
        $box = new MDiv($id, $content, 'm-expand-div-text-collapsed');

        $div[] = new MDiv("{$id}Div", array( $expandButton, $box ));

        parent::__construct($name, $div, $class, $attributes);
    }
}
?>
