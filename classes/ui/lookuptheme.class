class LookupTheme extends Theme
{
    var $title;
    var $content;
    var $footer;
    
    function LookupTheme()
    {
        $this->Theme();
        $this->title   = null;
        $this->content = '&nbsp;';
        $this->footer  = '&nbsp;';
        
        $this->AddScript('common.js');
    }
    
    function Lookup($title,$module,$item,$data,$labels,$filtro,$total,$page,$lines)
    { global $lookup_form, $lookup_field, $lookup_text, $frm_filtro;
        
        $url = "lookup.php?module=$module&action=lookup&item=$item" .
               // parametros requeridos para o lookup
               "&frm_filtro=$frm_filtro" .
               "&lookup_form=$lookup_form" .
               "&lookup_field=$lookup_field" .
               "&lookup_text=$lookup_text";
        
        $form = new Form('Filtrar Registros');
        //$form = new Form($title);
        $form->SetAction($url);
        $form->AddField(new TextField('Filtro','filtro',$filtro,30));
        
        // $data = $lookup->LookupInstituicoes($frm_filtro,20,$page,$total);
        
        $nb = new PageNavigator($total,$page,$lines,$url);
        
        // visualizar resultado
        $listing = new Listing();
        $listing->SetTitle($title);
        
        // definir rotulos das colunas
        $listing->SetLabels($labels);
        
        // definir ações para cada linha; observe os parâmetros posicionais
        // na definição do URL
        $listing->AddAction('ID','images/select.gif',
                            "javascript:Deliver(%0%,'%1%')");
        
        // passar os dados para o listing
        $listing->SetData($data);
        $listing->SetFooter($nb);
        
        // $this->Title('Lookup: &lt;' . htmlspecialchars($HTTP_REFERER) . '&gt;');
        $this->Content(array($form,$listing));
    }
}
?>
