define (PN_PAGE,'pn_page');

/**
 * Uma implementação de uma barra de navagação de páginas para resultados
 * de consultas
 */
class PageNavigator
{
    var $pageLength;
    var $pageNumber;
    var $action;
    var $queryRange;
    var $show_totals=false;
    
    function PageNavigator($length=20, // Number of records per page
                           $action='?' // Action URL
                          )
    {
        $this->pageNumber = MIOLO::_REQUEST(PN_PAGE);
        $this->pageLength = $length;
        
        $this->action     = $action;
        
        $this->queryRange = new QueryRange($this->pageNumber,
                                           $this->pageLength);
    }
    
    function SetAction($url)
    {
        $this->action = $url;
    }
    
    function SetShowTotals()
    {
        $this->show_totals = true;
    }
    
    function & GetQueryRange()
    {
        return $this->queryRange;
    }
    
    function GetTotalRows()
    {
        return $this->queryRange->total;
    }    
    
    function GetCurrentPage()
    {
        return (int) $this->pageNumber;
    }
    
    function SetCurrentPage($num)
    {
        $this->pageNumber = (int) $num;
        
        $this->queryRange = new QueryRange($this->pageNumber,
                                           $this->pageLength);
    }
    
    function GetTotalPages()
    {
        return (int) ( ( $this->queryRange->total + $this->pageLength - 1 ) / $this->pageLength );
    }    
    
    function Generate()
    {
        global $MIOLO,$MIOLOCONF;
        $theme = $MIOLOCONF['theme']['main'];
        $home = $MIOLO->GetThemeUrl('',$theme);

        $rowCount = $this->queryRange->total;

        $btn_first0 = "<img src='$home/images/pnfirst0.gif' border='0'>";
        $btn_first1 = "<img src='$home/images/pnfirst.gif' border='0'>";
        $btn_prev0  = "<img src='$home/images/pnprev0.gif' border='0'>";
        $btn_prev1  = "<img src='$home/images/pnprev.gif' border='0'>";
        $btn_next0  = "<img src='$home/images/pnnext0.gif' border='0'>";
        $btn_next1  = "<img src='$home/images/pnnext.gif' border='0'>";
        $btn_last0  = "<img src='$home/images/pnlast0.gif' border='0'>";
        $btn_last1  = "<img src='$home/images/pnlast.gif' border='0'>";

        echo "<!-- PageNavigator -->\n";
        echo "<table class=\"pageNavigator\" align=\"center\">\n";
        echo "  <tr>\n";
        
        if ( $this->pageNumber > 0 )
        {
            echo "    <td><a href=\"$this->action&" . PN_PAGE . "=0\">$btn_first1</a></td>\n";
            echo "    <td><a href=\"$this->action&" . PN_PAGE . "=" . ($this->pageNumber-1) . "\">$btn_prev1</a></td>\n";
        }
        
        else
        {
            echo "    <td>$btn_first0</td>\n";
            echo "    <td>$btn_prev0</td>\n";
        }
        
        //Total number of pages
        $pageCount = (int) ( ( $rowCount + $this->pageLength - 1 ) / $this->pageLength );
        
        echo "    <td width=\"100%\" align=\"center\">";
        
        if ( $pageCount >= 2 )
        {
            if ( $this->pageNumber < 10 )
            {
                $o = 0;
            }
            
            else
            {
                $o = $this->pageNumber - 10;
                
                if ( $o > 0 )
                {
                    echo "&nbsp;<a class=\"pageNavigatorLink\" href=\"$this->action&" . PN_PAGE . "=" . ($o - 1) . "\">...</a> ";
                }
            }
            
            for ( $i=0; $i<21 && $o<$pageCount; $i++,$o++ )
            {
                if ( $i > 0 )
                {
                    echo "&nbsp;";
                }
                
                $p = $o + 1;
                
                if ( $o != $this->pageNumber )
                {
                    echo "<a href=\"$this->action&" . PN_PAGE . "=$o\" class=\"pageNavigatorLink\" onMouseOver=\"top.status='Página $p'\">$p</a>";
                }
                
                else
                {
                    echo "<span class=\"pageNavigatorLink\">$p</span>";        
                }
            }
            
            if ( $o < $pageCount )
            {
                echo "&nbsp;<a class=\"pageNavigatorLink\" href=\"$this->action&" . PN_PAGE . "=$p\">...</a>";
            }
        }
        
        else
        {
            echo "&nbsp;";
        }
        
        echo "</td>\n";
        
        $maxRow = $this->pageNumber * $this->pageLength + $this->pageLength - 1;
        
        if ( $maxRow + 1 < $rowCount )
        {
            echo "    <td><a href=\"$this->action&" . PN_PAGE . "=" . ($this->pageNumber+1) . "\">$btn_next1</a></td>\n";
            echo "    <td><a href=\"$this->action&" . PN_PAGE . "=" . ($pageCount-1) . "\">$btn_last1</a></td>\n";
        }
        
        else
        {
            echo "    <td>$btn_next0</td>\n";
            echo "    <td>$btn_last0</td>\n";
        }

        echo "  </tr>\n";
        echo "  <tr>\n";
        echo "    <td align=\"center\" colspan=\"5\" class=\"pageNavigatorText\">\n";
        if ( $this->show_totals )
        {
            echo '      ('. _M('Page') . ' ' . ($this->GetPageNumber()+1) . ' ' . _M('of') . ' '.$this->GetTotalPages() . ")\n";
        }
        echo "    </td>\n";
        echo "  </tr>\n";
        echo "</table>\n";
    }
}

?>
