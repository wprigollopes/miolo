class StatusBar
{
    var $cols;
    
    function StatuBar($cols=null)
    {
        $this->cols=$cols;
    }
    
    function AddInfo($info)
    {
        $this->cols[] = $info;
    }
    
    function Generate()
    {
        echo "<!-- START OF STATUSBAR -->\n";
        echo "<table class=\"statusBar\" width=\"100%\" border=\"0\" cellspacing=\"2\" cellpadding=\"0\">\n";
        echo "  <tr class=\"statusBarRow\">\n";
        
        foreach($this->cols as $c)
        {
            echo "    <td class=\"statusBarCell\">$c</td>\n";
        }
        
        echo "  </tr>\n";
        echo "</table>\n";
        echo "<!-- END OF STATUSBAR -->\n";
    }
}

?>
