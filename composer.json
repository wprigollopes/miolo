{
    "name": "miolo/miolo",
    "description": "Miolo PHP Framework",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-mbstring": "*",
        "phpmailer/phpmailer": "^6.9",
        "dompdf/dompdf": "^2.0"
    },
    "autoload": {
        "classmap": [
            "classes/",
            "modules/"
        ],
        "files": [
            "classes/support.php"
        ],
        "exclude-from-classmap": [
            "classes/extensions/dompdf/",
            "classes/extensions/json.php",
            "modules/base/classes/phpmailer/",
            "modules/base/handlers/main.inc"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "vimeo/psalm": "^6.15"
    }
}
