function MyListingBox($title,$filter,$body,$footer)
{
    global $MIOLO,$MIOLOCONF;
		$theme = $MIOLOCONF['theme']['main'];
    	$home = $MIOLO->GetThemeUrl('',$theme);

    $rows[] = $filter;
    $rows[] = $body;
    $rows[] = $footer;
    $boxcolor = '#0164A7';
        
    echo "<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n";
    echo "  <tr valign=\"top\" bgcolor=\"$boxcolor\">\n";
    echo "    <td bgcolor=\"#FFFFFF\"><img src=\"$home/images/pix.gif\" width=\"3\" height=\"3\" alt=\"\"></td>\n";
    echo "    <td><img src=\"$home/images/fundodir.gif\" width=\"10\" height=\"22\ alt=\"\"></td>\n";
    echo "    <td valign='bottom' background=\"$home/images/fundo.gif\"><font class=\"formTitleText\"><b>&nbsp;&nbsp;$title&nbsp;&nbsp;</b></font></td>\n";
    echo "    <td align=\"right\"><img src=\"$home/images/fundoesq.gif\" width=\"10\" height=\"22\ alt=\"\"></td>\n";
    echo "    <td bgcolor=\"#FFFFFF\" align=\"right\"><img src=\"$home/images/pix.gif\" width=\"3\" height=\"3\" alt=\"\"></td>\n";
    echo "  </tr>\n";
    echo "</table>\n";
    echo "<table width=\"540\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n";
    echo "  <tr bgcolor=\"$boxcolor\"><td colspan=\"3\"><img src=\"$home/images/pix.gif\" width=\"1\" height=\"1\"></td></tr>\n";
    
    echo "  <tr bgcolor=\"$boxcolor\"><td colspan=\"3\">";
    foreach ( $rows as $r )
    {
        if ( $r )
        {
            echo $r;
        }
    }
    echo "</td></tr>\n";
    
    /*
    foreach ( $rows as $r )
    {
        if ( $r )
        {
            echo "  <tr bgcolor=\"#ffffff\">\n";
            echo "    <td background=\"$home/images/sl.gif\"><img src=\"$home/images/pix.gif\" width=\"3\" height=\"3\" alt=\"\"></td>\n";
            echo "    <td width=\"100%\">\n";
            echo "      <table width=\"600\" border=\"0\" cellpadding=\"5\" cellspacing=\"0\">\n";
            echo "        <tr><td>$r</td></tr>\n";
            echo "      </table></td>\n";
            echo "    <td background=\"$home/images/sr.gif\" align=\"right\"><img src=\"$home/images/pix.gif\" width=\"3\" height=\"3\" alt=\"\"></td>\n";
            echo "  </tr>\n";
        }
    }
    */
    
    echo "  <tr bgcolor=\"$boxcolor\">\n";
    echo "    <td colspan=\"3\"><img src=\"$home/images/pix.gif\" width=\"1\" height=\"1\"></td>\n";
    echo "  </tr>\n";
    echo "</table><br><br>\n";
    echo "\n";
}

?>
